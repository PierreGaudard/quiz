---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { locales, defaultLocale } from "../i18n/config";
import type { Locale } from "../i18n/config";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  showHeader?: boolean;
  locale?: Locale;
  /** Override hreflang paths per locale when slugs differ (e.g. subcategories). */
  hreflangPaths?: Partial<Record<Locale, string>>;
  /** Force noindex on this page (for user profiles, etc.). */
  noindex?: boolean;
}

const { title, description = "Test your knowledge with fun and interactive quizzes!", ogImage, showHeader = true, locale = "en", hreflangPaths, noindex } = Astro.props;

const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = Astro.url.pathname;
// Strip base and locale prefix to get the "page path"
let pagePath = currentPath.startsWith(BASE) ? currentPath.slice(BASE.length) : currentPath;
if (locale !== defaultLocale && pagePath.startsWith(`/${locale}`)) {
  pagePath = pagePath.slice(locale.length + 1) || '/';
}

const langMap: Record<Locale, string> = { en: "en", fr: "fr", es: "es" };
const ogLocaleMap: Record<Locale, string> = { en: "en_US", fr: "fr_FR", es: "es_ES" };

// Build absolute URLs for SEO tags — always use trailing slash to match Astro output
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || '';
const trailingPath = currentPath.endsWith('/') ? currentPath : `${currentPath}/`;
const canonicalUrl = `${siteUrl}${trailingPath}`;
---

<!doctype html>
<html lang={langMap[locale]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex" />

    {/* Self-referencing canonical */}
    <link rel="canonical" href={canonicalUrl} />

    {/* Open Graph */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocaleMap[locale]} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta property="og:site_name" content="Wizy" />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    {/* hreflang tags for SEO (absolute URLs) */}
    {locales.map((loc) => {
      const prefix = loc === defaultLocale ? '' : `/${loc}`;
      const locPath = hreflangPaths?.[loc] ?? pagePath;
      const href = `${siteUrl}${prefix}${locPath}`;
      return <link rel="alternate" hreflang={loc} href={href} />;
    })}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${hreflangPaths?.en ?? pagePath}`} />

    <link rel="icon" type="image/svg+xml" href={`${BASE}/favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" /></noscript>
    <title>{title}</title>
    <style is:global>
      @import "../styles/global.css";
    </style>
  </head>
  <body class="min-h-screen bg-gray-50">
    {showHeader && <Header locale={locale} langSwitchPaths={hreflangPaths} />}
    <slot />
    <Footer locale={locale} />
    <script is:inline>
      (function() {
        // Dynamic level calculation (matches levels.ts formula)
        function xpForLevel(lv) { if (lv <= 1) return 0; return Math.floor(10 * lv * lv - 10 * lv + 200); }
        function getLevelColor(lv) {
          if (lv >= 900) return 'bg-gradient-to-r from-red-500 to-yellow-500';
          if (lv >= 700) return 'bg-gradient-to-r from-amber-400 to-orange-500';
          if (lv >= 500) return 'bg-gradient-to-r from-violet-500 to-pink-500';
          if (lv >= 300) return 'bg-gradient-to-r from-blue-500 to-cyan-400';
          if (lv >= 200) return 'bg-violet-500';
          if (lv >= 100) return 'bg-amber-500';
          if (lv >= 50) return 'bg-blue-500';
          if (lv >= 20) return 'bg-teal-500';
          if (lv >= 10) return 'bg-green-500';
          if (lv >= 5) return 'bg-emerald-500';
          return 'bg-gray-400';
        }
        function getLevel(xp) {
          var lv = 1;
          for (var i = 2; i <= 1000; i++) { if (xp >= xpForLevel(i)) lv = i; else break; }
          return { level: lv, color: getLevelColor(lv) };
        }

        var currentXp = 0;

        function updateHeader(u) {
          var lv = getLevel(u.xp || 0);
          currentXp = u.xp || 0;
          var loggedOut = document.getElementById('logged-out-menu');
          var loggedIn = document.getElementById('logged-in-menu');
          var avatar = document.getElementById('header-avatar');
          var username = document.getElementById('header-username');
          var levelBadge = document.getElementById('header-level');
          if (loggedOut) loggedOut.style.display = 'none';
          if (loggedIn) loggedIn.style.display = 'block';
          if (avatar) {
            if (u.avatar) { avatar.innerHTML = '<img src="' + u.avatar + '" class="w-full h-full object-cover" />'; }
            else { avatar.textContent = u.username[0].toUpperCase(); }
          }
          if (username) username.textContent = u.username;
          if (levelBadge) { levelBadge.textContent = 'Lv.' + lv.level; levelBadge.className = 'text-[10px] font-bold px-1.5 py-0.5 rounded text-white ' + lv.color; }
        }

        fetch('/api/auth/me').then(function(r) { return r.json(); }).then(function(data) {
          if (!data.user) return;
          updateHeader(data.user);
          var lv = getLevel(data.user.xp || 0);

          // Listen for XP gain events from quiz player
          window.addEventListener('wizy-xp-gain', function(e) {
            var amount = e.detail.amount;
            currentXp += amount;
            var lv = getLevel(currentXp);
            var levelBadge = document.getElementById('header-level');
            if (levelBadge) { levelBadge.textContent = 'Lv.' + lv.level; levelBadge.className = 'text-[10px] font-bold px-1.5 py-0.5 rounded text-white ' + lv.color; }

            // Update mobile level badge in real-time
            var mobileIcon = document.getElementById('mobile-user-icon');
            if (mobileIcon) {
              var mobileLvSpan = mobileIcon.querySelector('span:last-child');
              if (mobileLvSpan && mobileLvSpan.textContent.indexOf('Lv.') !== -1) {
                mobileLvSpan.textContent = 'Lv.' + lv.level;
                mobileLvSpan.className = 'text-[10px] font-bold px-1.5 py-0.5 rounded text-white shrink-0 ' + lv.color;
              }
            }

            // Show XP popup next to level badge
            var popup = document.createElement('span');
            popup.textContent = '+' + amount + ' XP';
            popup.className = 'absolute -top-6 right-0 text-xs font-black text-yellow-400 whitespace-nowrap animate-bounce';
            popup.style.textShadow = '0 1px 3px rgba(0,0,0,0.3)';
            var container = document.getElementById('logged-in-menu');
            if (container) { container.style.position = 'relative'; container.appendChild(popup); }
            setTimeout(function() { if (popup.parentNode) popup.parentNode.removeChild(popup); }, 1500);
          });

          // Update mobile user icon (top right) — show avatar + username + level
          var mobileIcon = document.getElementById('mobile-user-icon');
          if (mobileIcon) {
            var profileMobilePath = window.location.pathname.startsWith('/fr/') ? '/fr/profil/' : window.location.pathname.startsWith('/es/') ? '/es/perfil/' : '/profile/';
            mobileIcon.href = profileMobilePath;
            var avatarMHtml = data.user.avatar
              ? '<img src="' + data.user.avatar + '" class="w-7 h-7 rounded-full object-cover border-2 border-white/30 shrink-0" />'
              : '<span class="w-7 h-7 rounded-full bg-violet-500 flex items-center justify-center text-white text-xs font-bold shrink-0">' + data.user.username[0].toUpperCase() + '</span>';
            mobileIcon.innerHTML = avatarMHtml
              + '<span class="max-w-[72px] truncate text-white text-xs font-bold leading-tight">' + data.user.username + '</span>'
              + '<span class="text-[10px] font-bold px-1.5 py-0.5 rounded text-white shrink-0 ' + lv.color + '">Lv.' + lv.level + '</span>';
            mobileIcon.className = 'sm:hidden flex items-center gap-1.5 px-2 py-1.5 rounded-lg bg-white/10 hover:bg-white/20 transition-colors';
            mobileIcon.setAttribute('aria-label', data.user.username);
          }

          // Update mobile menu
          var mobileAuth = document.getElementById('mobile-auth-links');
          if (mobileAuth) {
            var profilePath = window.location.pathname.startsWith('/fr/') ? '/fr/profil/' : window.location.pathname.startsWith('/es/') ? '/es/perfil/' : '/profile/';
            var avatarMobileHtml = data.user.avatar ? '<img src="' + data.user.avatar + '" class="w-6 h-6 rounded-full object-cover" />' : '<span class="w-6 h-6 rounded-full bg-violet-500 flex items-center justify-center text-white text-[10px] font-bold">' + data.user.username[0].toUpperCase() + '</span>';
            mobileAuth.innerHTML = '<a href="' + profilePath + '" class="flex items-center gap-3 px-3 py-2.5 rounded text-white hover:bg-white/10 text-sm font-medium">' + avatarMobileHtml + ' ' + data.user.username + ' <span class="text-[10px] font-bold px-1.5 py-0.5 rounded text-white ' + lv.color + ' ml-auto">Lv.' + lv.level + '</span></a>';
          }

          // Logout button handler
          var logoutBtn = document.getElementById('header-logout-btn');
          if (logoutBtn) {
            logoutBtn.addEventListener('click', function() {
              fetch('/api/auth/logout', { method: 'POST' }).then(function() { window.location.reload(); });
            });
          }
        }).catch(function() {});
      })();
    </script>
  </body>
</html>
