---
import { localePath, withBase } from "../utils/base";
import { categoryIcons } from "../data/icons";
import { getCategories, categoryDefs, getSubcategoryImageSlug } from "../data/categories";
import { slugifySubcategory } from "../data/quizzes";
import { t } from "../i18n/ui";
import { locales, defaultLocale } from "../i18n/config";
import type { Locale } from "../i18n/config";

interface Props {
  locale?: Locale;
  /** Override lang switch paths per locale (for subcategory pages with locale-specific slugs). */
  langSwitchPaths?: Partial<Record<Locale, string>>;
}
const { locale = "en", langSwitchPaths } = Astro.props;
const lp = (path: string) => localePath(path, locale);
const currentPath = Astro.url.pathname;
const cats = getCategories(locale);

// Locale-aware slug mapping for static pages
const slugs: Record<string, Record<string, string>> = {
  login: { en: "/login", fr: "/connexion", es: "/iniciar-sesion" },
  signup: { en: "/sign-up", fr: "/inscription", es: "/registrarse" },
  create: { en: "/create", fr: "/creer", es: "/crear" },
  leaderboard: { en: "/leaderboard", fr: "/classement", es: "/clasificacion" },
  profile: { en: "/profile", fr: "/profil", es: "/perfil" },
  search: { en: "/search", fr: "/recherche", es: "/buscar" },
};
const s = (key: string) => slugs[key]?.[locale] || slugs[key]?.en || key;

// --- Language switcher URL helpers ---
const pagePath = currentPath.replace(/^\/?/, "/");
// Strip current locale prefix so we have a locale-neutral path
const strippedPath =
  locale !== defaultLocale && pagePath.startsWith(`/${locale}`)
    ? pagePath.slice(`/${locale}`.length) || "/"
    : pagePath;

const localeLabels: Record<Locale, string> = { en: "English", fr: "Français", es: "Español" };
const localeShort: Record<Locale, string> = { en: "EN", fr: "FR", es: "ES" };
const localeSwitchLinks = locales.map((l) => {
  // Use custom path if provided (for subcategory pages), otherwise default
  const path = langSwitchPaths?.[l] ?? strippedPath;
  return {
    locale: l,
    href: localePath(path, l),
    label: localeLabels[l],
    short: localeShort[l],
    active: l === locale,
  };
});
// SVG flags (4x3 ratio, US/FR/ES)
const flags: Record<Locale, string> = {
  en: `<svg viewBox="0 0 60 30" class="w-5 h-3.5 rounded-sm shrink-0"><rect width="60" height="30" fill="#fff"/><g fill="#B22234"><rect width="60" height="2.31"/><rect y="4.62" width="60" height="2.31"/><rect y="9.23" width="60" height="2.31"/><rect y="13.85" width="60" height="2.31"/><rect y="18.46" width="60" height="2.31"/><rect y="23.08" width="60" height="2.31"/><rect y="27.69" width="60" height="2.31"/></g><rect width="24" height="16.15" fill="#3C3B6E"/><g fill="#fff" font-size="2"><text x="2" y="2.5">★</text><text x="6" y="2.5">★</text><text x="10" y="2.5">★</text><text x="14" y="2.5">★</text><text x="18" y="2.5">★</text><text x="4" y="5.2">★</text><text x="8" y="5.2">★</text><text x="12" y="5.2">★</text><text x="16" y="5.2">★</text><text x="2" y="7.9">★</text><text x="6" y="7.9">★</text><text x="10" y="7.9">★</text><text x="14" y="7.9">★</text><text x="18" y="7.9">★</text><text x="4" y="10.6">★</text><text x="8" y="10.6">★</text><text x="12" y="10.6">★</text><text x="16" y="10.6">★</text><text x="2" y="13.3">★</text><text x="6" y="13.3">★</text><text x="10" y="13.3">★</text><text x="14" y="13.3">★</text><text x="18" y="13.3">★</text></g></svg>`,
  fr: `<svg viewBox="0 0 3 2" class="w-5 h-3.5 rounded-sm shrink-0"><rect width="1" height="2" fill="#002395"/><rect x="1" width="1" height="2" fill="#fff"/><rect x="2" width="1" height="2" fill="#ED2939"/></svg>`,
  es: `<svg viewBox="0 0 3 2" class="w-5 h-3.5 rounded-sm shrink-0"><rect width="3" height="2" fill="#AA151B"/><rect y="0.5" width="3" height="1" fill="#F1BF00"/></svg>`,
};

const megaCategories = cats.map((cat, i) => ({
  label: cat.name, slug: cat.slug, baseSlug: categoryDefs[i].slug, href: lp(`/${cat.slug}`), color: cat.color,
  coverImage: cat.coverImage,
  subs: cat.subcategories.map((sub) => ({
    name: sub,
    slug: slugifySubcategory(sub),
    href: lp(`/${cat.slug}/${slugifySubcategory(sub)}`),
    image: `/images/sub-${getSubcategoryImageSlug(sub, locale)}.webp`,
  })),
}));

// Theme-based navigation with category groupings
const themeIcons: Record<string, string> = {
  culture: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>`,
  divertissement: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  langues: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/></svg>`,
  nature: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  sport: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
  quotidien: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1"/></svg>`,
};

const themes: { id: string; label: Record<string, string>; categorySlugs: string[] }[] = [
  { id: "culture", label: { en: "Culture", fr: "Culture", es: "Cultura" }, categorySlugs: ["cinema"] },
  { id: "divertissement", label: { en: "Entertainment", fr: "Divertissement", es: "Entretenimiento" }, categorySlugs: ["anime", "jeux-video"] },
  { id: "langues", label: { en: "Languages", fr: "Langues", es: "Idiomas" }, categorySlugs: [] },
  { id: "nature", label: { en: "Nature", fr: "Nature", es: "Naturaleza" }, categorySlugs: [] },
  { id: "sport", label: { en: "Sports", fr: "Sport", es: "Deportes" }, categorySlugs: ["sport"] },
  { id: "quotidien", label: { en: "Daily Life", fr: "Vie Quotidienne", es: "Vida Cotidiana" }, categorySlugs: ["geographie"] },
];

const resolvedThemes = themes.map((theme) => ({
  ...theme,
  name: theme.label[locale] || theme.label.en,
  icon: themeIcons[theme.id],
  categories: theme.categorySlugs
    .map((slug) => megaCategories.find((c) => c.baseSlug === slug))
    .filter(Boolean) as typeof megaCategories,
}));

const comingSoonLabel: Record<string, string> = { en: "Coming soon", fr: "Bientot disponible", es: "Proximamente" };
---

<header class="header-wrapper sticky top-0 z-50 shadow-lg">
  {/* ===== ROW 1: Logo + Search + Mon compte ===== */}
  <div class="bg-[#1a0e42]">
    <div class="max-w-7xl mx-auto px-4 flex items-center h-14 gap-4">
      <a href={lp('/')} class="flex items-center gap-2 shrink-0 group">
        <div class="w-10 h-10 bg-gradient-to-br from-violet-500 to-purple-600 rounded-lg flex items-center justify-center shadow-lg group-hover:scale-105 transition-transform border border-white/20">
          <span class="text-white font-display font-black text-xl leading-none">W</span>
        </div>
        <div class="hidden sm:flex flex-col leading-none">
          <span class="font-display font-extrabold text-white text-lg tracking-tight">Wi<span class="text-yellow-400">zy</span></span>
        </div>
      </a>

      <form action={lp(s('search'))} method="GET" class="flex-1 max-w-lg mx-auto hidden md:block">
        <div class="relative">
          <input type="search" name="q" placeholder={t(locale, "nav.search")} class="w-full h-9 pl-4 pr-12 rounded bg-white/10 border border-white/20 text-white placeholder-white/40 text-sm focus:outline-none focus:bg-white/15 focus:border-white/40 transition-all" />
          <button type="submit" class="absolute right-0 top-0 h-9 w-10 rounded-r bg-yellow-500 hover:bg-yellow-400 flex items-center justify-center transition-colors" aria-label="Search">
            <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={2.5}><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
          </button>
        </div>
      </form>

      <div class="flex items-center gap-2 ml-auto shrink-0">
        {/* Language switcher dropdown */}
        <div class="relative group hidden sm:block mr-1">
          <button class="flex items-center gap-1.5 px-2.5 py-1.5 rounded bg-white/10 hover:bg-white/20 border border-white/20 text-white text-sm font-medium transition-all">
            <Fragment set:html={flags[locale]} />
            <span class="text-xs font-bold">{localeShort[locale]}</span>
            <svg class="w-3 h-3 text-white/60 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute top-full right-0 mt-1 w-44 bg-white rounded-lg shadow-2xl border border-gray-200 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-1 group-hover:translate-y-0 z-50">
            <div class="p-1">
              {localeSwitchLinks.map((l) => (
                <a
                  href={l.href}
                  class={`flex items-center gap-2.5 px-3 py-2 rounded-md text-sm transition-colors ${
                    l.active
                      ? "bg-violet-50 text-violet-700 font-semibold"
                      : "text-gray-700 hover:bg-gray-50"
                  }`}
                >
                  <Fragment set:html={flags[l.locale]} />
                  <span>{l.label}</span>
                  {l.active && (
                    <svg class="w-4 h-4 ml-auto text-violet-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  )}
                </a>
              ))}
            </div>
          </div>
        </div>
        <div class="relative group hidden sm:block" id="user-menu">
          {/* Default: logged out state */}
          <div id="logged-out-menu">
            <button class="flex items-center gap-2 px-4 py-1.5 rounded bg-white text-[#1a0e42] text-sm font-bold hover:bg-gray-100 transition-all shadow-sm">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={2.5}><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
              {t(locale, "nav.account")}
            </button>
            <div class="absolute top-full right-0 mt-1 w-52 bg-white rounded-lg shadow-2xl border border-gray-200 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-1 group-hover:translate-y-0 z-50">
              <div class="p-1.5">
                <a href={lp(s('login'))} class="flex items-center gap-3 px-3 py-2.5 rounded text-sm font-medium text-gray-700 hover:bg-violet-50 hover:text-violet-700 transition-colors">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={2}><path stroke-linecap="round" stroke-linejoin="round" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" /></svg>
                  {t(locale, "auth.login")}
                </a>
                <a href={lp(s('signup'))} class="flex items-center gap-3 px-3 py-2.5 rounded text-sm font-bold text-violet-700 hover:bg-violet-50 transition-colors">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={2}><path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" /></svg>
                  {t(locale, "auth.signup")}
                </a>
              </div>
            </div>
          </div>
          {/* Logged in state (hidden by default, shown by JS) */}
          <div id="logged-in-menu" style="display:none" class="relative group">
            <button class="flex items-center gap-2 px-3 py-1 rounded bg-white text-[#1a0e42] text-sm font-bold hover:bg-gray-100 transition-all shadow-sm cursor-pointer">
              <div id="header-avatar" class="w-7 h-7 rounded-full bg-violet-500 flex items-center justify-center text-white text-xs font-bold overflow-hidden"></div>
              <span id="header-username" class="max-w-[80px] truncate"></span>
              <span id="header-level" class="text-[10px] font-bold px-1.5 py-0.5 rounded text-white bg-gray-400"></span>
              <svg class="w-3 h-3 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="absolute top-full right-0 mt-1 w-52 bg-white rounded-lg shadow-2xl border border-gray-200 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-1 group-hover:translate-y-0 z-50">
              <div class="p-1.5">
                <a href={lp(s('profile'))} class="flex items-center gap-3 px-3 py-2.5 rounded text-sm font-medium text-gray-700 hover:bg-violet-50 hover:text-violet-700 transition-colors">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={2}><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                  {t(locale, "nav.profile") || "My Profile"}
                </a>
                <a href={lp(s('leaderboard'))} class="flex items-center gap-3 px-3 py-2.5 rounded text-sm font-medium text-gray-700 hover:bg-violet-50 hover:text-violet-700 transition-colors">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M5 16L3 5l5.5 5L12 4l3.5 6L21 5l-2 11H5zm14 3c0 .6-.4 1-1 1H6c-.6 0-1-.4-1-1v-1h14v1z"/></svg>
                  {t(locale, "ranking.title")}
                </a>
                <a href={lp(s('create'))} class="flex items-center gap-3 px-3 py-2.5 rounded text-sm font-medium text-gray-700 hover:bg-violet-50 hover:text-violet-700 transition-colors">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={2}><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
                  {t(locale, "nav.create")}
                </a>
                <div class="border-t border-gray-100 my-1"></div>
                <button id="header-logout-btn" class="w-full flex items-center gap-3 px-3 py-2.5 rounded text-sm font-medium text-red-600 hover:bg-red-50 transition-colors cursor-pointer">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={2}><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
                  {t(locale, "auth.logout") || "Log out"}
                </button>
              </div>
            </div>
          </div>
        </div>
        {/* Keep dropdown links for create/leaderboard */}
        <div class="relative group hidden sm:block">
          <div class="absolute top-full right-0 mt-1 w-52 bg-white rounded-lg shadow-2xl border border-gray-200 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-1 group-hover:translate-y-0 z-50" style="display:none">
            <div class="p-1.5">
              <a href={lp(s('create'))} class="flex items-center gap-3 px-3 py-2.5 rounded text-sm font-medium text-gray-700 hover:bg-violet-50 hover:text-violet-700 transition-colors">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={2}><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
                {t(locale, "nav.create")}
              </a>
              <a href={lp(s('leaderboard'))} class="flex items-center gap-3 px-3 py-2.5 rounded text-sm font-medium text-gray-700 hover:bg-violet-50 hover:text-violet-700 transition-colors">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={2}><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
                {t(locale, "ranking.title")}
              </a>
            </div>
          </div>
        </div>
        <a id="mobile-user-icon" href={lp(s('login'))} class="sm:hidden flex items-center justify-center w-10 h-10 rounded-lg text-white/70 hover:text-white hover:bg-white/10 transition-colors" aria-label={t(locale, "auth.login")}>
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={2}><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
        </a>
        <button class="lg:hidden flex items-center justify-center w-10 h-10 rounded-lg text-white hover:bg-white/10 transition-colors" onclick="document.getElementById('mobile-menu').classList.toggle('hidden')" aria-label="Menu">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={2}><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" /></svg>
        </button>
      </div>
    </div>
  </div>

  {/* ===== ROW 2: Theme navigation bar ===== */}
  <div class="bg-[#2d1b69] border-t border-white/10 hidden lg:block">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="flex items-stretch h-11">
        {resolvedThemes.map((theme, idx) => {
          const singleCat = theme.categories.length === 1 ? theme.categories[0] : null;
          const themeHref = singleCat ? singleCat.href : undefined;
          return (
          <div class={`relative group flex ${idx > 0 ? "border-l border-white/10" : ""}`}>
            {themeHref ? (
              <a href={themeHref} class="flex items-center gap-2 px-4 text-sm font-bold text-white/80 hover:text-white hover:bg-white/10 transition-all duration-150 whitespace-nowrap">
                <span class="text-white/50 group-hover:text-white/80 transition-colors" set:html={theme.icon} />
                <span>{theme.name}</span>
                <svg class="w-3 h-3 opacity-40 group-hover:opacity-80 transition-opacity mt-px" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={3}><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </a>
            ) : (
              <button class="flex items-center gap-2 px-4 text-sm font-bold text-white/80 hover:text-white hover:bg-white/10 transition-all duration-150 whitespace-nowrap cursor-pointer">
                <span class="text-white/50 group-hover:text-white/80 transition-colors" set:html={theme.icon} />
                <span>{theme.name}</span>
                <svg class="w-3 h-3 opacity-40 group-hover:opacity-80 transition-opacity mt-px" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={3}><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </button>
            )}

            {/* ===== MEGA MENU ===== */}
            {theme.id === "sport" && theme.categories.length === 1 ? (
              /* Sport: wide mega menu with subcategory image cards */
              <div class="absolute top-full left-0 mt-0 bg-white shadow-2xl rounded-b-xl border border-gray-200 border-t-2 border-t-violet-600 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-1 group-hover:translate-y-0 z-50" style="width: max-content; max-width: 680px;">
                <div class="p-4">
                  <div class="grid grid-cols-3 gap-2">
                    {theme.categories[0].subs.map((sub) => (
                      <a href={sub.href} class="group/sub flex flex-col rounded-xl overflow-hidden border border-gray-100 hover:border-violet-200 hover:shadow-md transition-all">
                        <div class="relative h-16 overflow-hidden">
                          <img src={withBase(sub.image)} alt={sub.name} width="800" height="450" class="w-full h-full object-cover group-hover/sub:scale-105 transition-transform duration-300" />
                          <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent" />
                        </div>
                        <div class="px-2.5 py-2 bg-white">
                          <span class="text-[12px] font-semibold text-gray-700 group-hover/sub:text-violet-700 transition-colors leading-tight line-clamp-1">{sub.name}</span>
                        </div>
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            ) : theme.categories.length > 0 ? (
              /* Other themes with categories: simple category cards */
              <div class="absolute top-full left-0 mt-0 min-w-[280px] bg-white shadow-2xl rounded-b-xl border border-gray-200 border-t-2 border-t-violet-600 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-1 group-hover:translate-y-0 z-50">
                <div class="p-2 space-y-0.5">
                  {theme.categories.map((cat) => (
                    <a href={cat.href} class="group/card flex items-center gap-3 p-3 rounded-lg hover:bg-violet-50 transition-colors">
                      <img src={withBase(cat.coverImage)} alt={cat.label} width="800" height="450" class="w-10 h-10 rounded-xl object-cover shrink-0 shadow-sm" />
                      <div class="flex-1 min-w-0">
                        <span class="text-sm font-bold text-gray-800 group-hover/card:text-violet-700">{cat.label}</span>
                        <p class="text-[11px] text-gray-400 mt-0.5 line-clamp-1">{cat.subs.slice(0, 4).map((s) => s.name).join(", ")}</p>
                      </div>
                      <svg class="w-4 h-4 text-gray-300 group-hover/card:text-violet-400 transition-colors shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                    </a>
                  ))}
                </div>
              </div>
            ) : (
              /* No categories: coming soon */
              <div class="absolute top-full left-0 mt-0 min-w-[240px] bg-white shadow-2xl rounded-b-xl border border-gray-200 border-t-2 border-t-violet-600 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-1 group-hover:translate-y-0 z-50">
                <div class="p-6 text-center">
                  <div class="w-10 h-10 bg-gray-100 rounded-xl flex items-center justify-center mx-auto mb-2 text-gray-400" set:html={theme.icon} />
                  <p class="text-sm font-semibold text-gray-500">{comingSoonLabel[locale] || comingSoonLabel.en}</p>
                  <p class="text-xs text-gray-400 mt-1">{theme.name}</p>
                </div>
              </div>
            )}
          </div>
          );
        })}

        <div class="flex-1"></div>
        <a href={lp(s("create"))} class="flex items-center gap-2 px-5 text-sm font-bold bg-yellow-500 text-white hover:bg-yellow-400 transition-all whitespace-nowrap">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
          {t(locale, "nav.create")}
        </a>
      </nav>
    </div>
  </div>

  {/* Mobile menu */}
  <div id="mobile-menu" class="hidden lg:hidden border-t border-white/10 bg-[#241558]">
    <div class="max-w-7xl mx-auto px-4 py-3 space-y-1">
      <form action={lp(s('search'))} method="GET" class="relative mb-3">
        <input type="search" name="q" placeholder={t(locale, "nav.search")} class="w-full h-10 pl-4 pr-12 rounded bg-white/10 border border-white/20 text-white placeholder-white/50 text-sm focus:outline-none focus:bg-white/15 focus:border-white/40" />
        <button type="submit" class="absolute right-0 top-0 h-10 w-11 rounded-r bg-yellow-500 flex items-center justify-center" aria-label="Search">
          <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={2.5}><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
        </button>
      </form>
      {resolvedThemes.filter((th) => th.categories.length > 0).map((theme) => (
        <div>
          <p class="text-[10px] font-black text-white/30 uppercase tracking-widest px-3 pt-3 pb-1">{theme.name}</p>
          {theme.id === "sport" && theme.categories.length === 1 ? (
            /* Sport: show subcategories */
            theme.categories[0].subs.map((sub) => (
              <a href={sub.href} class="flex items-center gap-3 px-3 py-2 rounded text-white/80 hover:text-white hover:bg-white/10 text-sm font-medium transition-colors">
                <img src={withBase(sub.image)} alt={sub.name} width="800" height="450" class="w-6 h-6 rounded object-cover" />
                {sub.name}
              </a>
            ))
          ) : (
            /* Other themes: show category links */
            theme.categories.map((cat) => (
              <a href={cat.href} class="flex items-center gap-3 px-3 py-2.5 rounded text-white/80 hover:text-white hover:bg-white/10 text-sm font-medium transition-colors">
                <img src={withBase(cat.coverImage)} alt={cat.label} width="800" height="450" class="w-6 h-6 rounded-md object-cover" />
                {cat.label}
              </a>
            ))
          )}
        </div>
      ))}
      <div class="border-t border-white/10 my-2"></div>
      <a href={lp(s('create'))} class="flex items-center gap-3 px-3 py-2.5 rounded bg-yellow-500 text-white text-sm font-bold">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
        {t(locale, "nav.create")}
      </a>
      <div id="mobile-auth-links">
        <a href={lp(s('login'))} class="flex items-center gap-3 px-3 py-2.5 rounded text-white/80 hover:text-white hover:bg-white/10 text-sm font-medium">{t(locale, "auth.login")}</a>
      </div>
      <a href={lp(s('leaderboard'))} class="flex items-center gap-3 px-3 py-2.5 rounded text-white/80 hover:text-white hover:bg-white/10 text-sm font-medium">{t(locale, "ranking.title")}</a>
      <div class="border-t border-white/10 my-2"></div>
      <div class="px-3 py-1 space-y-0.5">
        <p class="text-xs font-bold text-white/40 uppercase tracking-wider mb-1.5">{t(locale, "misc.language")}</p>
        {localeSwitchLinks.map((l) => (
          <a
            href={l.href}
            class={`flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm transition-colors ${
              l.active
                ? "bg-white/15 text-white font-semibold"
                : "text-white/70 hover:text-white hover:bg-white/10"
            }`}
          >
            <Fragment set:html={flags[l.locale]} />
            <span>{l.label}</span>
            {l.active && (
              <svg class="w-4 h-4 ml-auto text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            )}
          </a>
        ))}
      </div>
    </div>
  </div>
</header>
