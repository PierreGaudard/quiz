---
import Layout from "../layouts/Layout.astro";
import { localePath } from "../utils/base";
import { t } from "../i18n/ui";
import type { Locale } from "../i18n/config";

const locale: Locale = "en";
const lp = (path: string) => localePath(path, locale);
---

<Layout title="Legal Notices | Wizy Quiz Platform" description="Legal notices for the Wizy quiz platform, including publisher information, hosting details and intellectual property." locale={locale}>
  <main class="max-w-3xl mx-auto px-4 py-12">
    <nav class="flex items-center gap-1.5 text-xs text-gray-500 mb-8" aria-label="Breadcrumb">
      <a href={lp("/")} class="hover:text-violet-600 transition-colors font-medium">{t(locale, "breadcrumb.home")}</a>
      <svg class="w-3 h-3 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      <span class="text-gray-700 font-semibold">Legal Notices</span>
    </nav>

    <h1 class="font-display text-3xl font-black text-gray-900 mb-8">Legal Notices</h1>

    <div class="prose prose-gray max-w-none space-y-8 text-sm leading-relaxed text-gray-700">

      <section>
        <h2 class="font-display text-lg font-bold text-gray-900 mb-3">1. Site publisher</h2>
        <p>The website <strong>Wizy</strong> (accessible at <strong>https://wizy.com</strong>) is published by:</p>
        <ul class="list-disc pl-5 space-y-1 mt-2">
          <li><strong>Name:</strong> Pierre Gaudard</li>
          <li><strong>Status:</strong> Individual</li>
          <li><strong>Email address:</strong> pierretartare94440@gmail.com</li>
        </ul>
      </section>

      <section>
        <h2 class="font-display text-lg font-bold text-gray-900 mb-3">2. Hosting provider</h2>
        <p>The site is hosted by:</p>
        <ul class="list-disc pl-5 space-y-1 mt-2">
          <li><strong>Company name:</strong> Cloudflare, Inc.</li>
          <li><strong>Address:</strong> 101 Townsend Street, San Francisco, CA 94107, United States</li>
          <li><strong>Website:</strong> cloudflare.com</li>
        </ul>
      </section>

      <section>
        <h2 class="font-display text-lg font-bold text-gray-900 mb-3">3. Publication director</h2>
        <p>The publication director is <strong>Pierre Gaudard</strong>.</p>
        <p>Contact: pierretartare94440@gmail.com</p>
      </section>

      <section>
        <h2 class="font-display text-lg font-bold text-gray-900 mb-3">4. Intellectual property</h2>
        <p>All content on the Wizy website (texts, graphics, images, logos, icons, sounds, software, quizzes, questions and answers) is the exclusive property of Pierre Gaudard or its partners and is protected by French and international intellectual property laws.</p>
        <p>Any reproduction, representation, modification, publication, adaptation or exploitation of all or part of the site elements, by any means or process, is prohibited without prior written authorisation from Pierre Gaudard.</p>
      </section>

      <section>
        <h2 class="font-display text-lg font-bold text-gray-900 mb-3">5. Personal data</h2>
        <p>Personal data processing is detailed in our <a href={lp("/privacy-policy")} class="text-violet-600 hover:text-violet-800 font-medium">Privacy Policy</a>.</p>
      </section>

      <section>
        <h2 class="font-display text-lg font-bold text-gray-900 mb-3">6. Cookies</h2>
        <p>The Wizy website only uses strictly necessary technical cookies (progress saving, user preferences). These cookies do not collect any personal data for advertising or profiling purposes.</p>
      </section>

      <section>
        <h2 class="font-display text-lg font-bold text-gray-900 mb-3">7. Limitation of liability</h2>
        <p>The information and content on the Wizy website are provided for informational and entertainment purposes. Pierre Gaudard cannot be held responsible for errors or omissions in quiz questions and answers.</p>
        <p>Use of the site is at the user's own risk. Pierre Gaudard shall not be held liable for any direct or indirect damages resulting from the use of the site.</p>
      </section>

      <section>
        <h2 class="font-display text-lg font-bold text-gray-900 mb-3">8. Applicable law</h2>
        <p>These legal notices are governed by French law. In the event of a dispute, French courts shall have sole jurisdiction.</p>
      </section>

      <p class="text-xs text-gray-400 pt-4 border-t border-gray-200">Last updated: March 2026</p>
    </div>
  </main>
</Layout>
