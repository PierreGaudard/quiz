---
import Layout from "../../layouts/Layout.astro";
import { categories, gameTypes } from "../../data/categories";
import { getQuizzesByCategory, getFeaturedQuiz } from "../../data/quizzes";
import CategoryPage from "../../components/CategoryPage";

export function getStaticPaths() {
  return categories.map((cat) => ({
    params: { slug: cat.slug },
  }));
}

const { slug } = Astro.params;
const category = categories.find((c) => c.slug === slug)!;
const quizzes = getQuizzesByCategory(slug!);
const featured = getFeaturedQuiz(slug!);

// Game types present in this category
const availableGameTypes = gameTypes.filter((gt) => quizzes.some((q) => q.gameType === gt.id));

// Group quizzes by game type
const quizzesByType = availableGameTypes
  .map((gt) => ({
    ...gt,
    quizzes: quizzes.filter((q) => q.gameType === gt.id),
  }));
---

<Layout title={`Quiz ${category.name} - Teste tes connaissances`} description={category.seoIntro || category.description}>
  <CategoryPage
    client:load
    category={category}
    quizzes={quizzes}
    featured={featured}
    gameTypes={availableGameTypes}
    quizzesByType={quizzesByType}
  />
</Layout>
