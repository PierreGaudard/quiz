---
import Layout from "../../layouts/Layout.astro";
import QuizCreator from "../../components/QuizCreator";
---

<Layout title="Create Your Own Quiz - Wizy" description="Build your own quiz in minutes. Choose a category, add your questions and share your unique link." locale="en">
  <div class="max-w-4xl mx-auto px-4 pt-8">
    <h1 class="font-display text-3xl font-bold text-gray-900 mb-6">New quiz: add your questions</h1>
  </div>
  <QuizCreator client:load />
</Layout>
