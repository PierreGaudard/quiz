---
import Layout from "../layouts/Layout.astro";
import { localePath } from "../utils/base";
import { t } from "../i18n/ui";
import type { Locale } from "../i18n/config";

const locale: Locale = "en";
const lp = (path: string) => localePath(path, locale);

const mockPlayers = [
  { rank: 1, username: "QuizMaster_Alex", level: 42, xp: 28450, quizzes: 312, avatar: "A" },
  { rank: 2, username: "BrainStorm_Marie", level: 39, xp: 25200, quizzes: 287, avatar: "M" },
  { rank: 3, username: "Le_Savant_Hugo", level: 37, xp: 23100, quizzes: 264, avatar: "H" },
  { rank: 4, username: "Clara_Quiz", level: 34, xp: 20800, quizzes: 241, avatar: "C" },
  { rank: 5, username: "Thomas_Le_Pro", level: 31, xp: 18600, quizzes: 218, avatar: "T" },
  { rank: 6, username: "Sophie_Culture", level: 29, xp: 16900, quizzes: 195, avatar: "S" },
  { rank: 7, username: "NicoQuiz42", level: 27, xp: 15200, quizzes: 178, avatar: "N" },
  { rank: 8, username: "Camille_GK", level: 25, xp: 13800, quizzes: 162, avatar: "C" },
  { rank: 9, username: "JulienSport", level: 23, xp: 12100, quizzes: 145, avatar: "J" },
  { rank: 10, username: "Emma_Trivia", level: 21, xp: 10500, quizzes: 129, avatar: "E" },
  { rank: 11, username: "LucasGeo", level: 19, xp: 9200, quizzes: 112, avatar: "L" },
  { rank: 12, username: "Manon_Cine", level: 17, xp: 7800, quizzes: 96, avatar: "M" },
  { rank: 13, username: "Antoine_Quiz", level: 15, xp: 6400, quizzes: 81, avatar: "A" },
];

const RANK_STYLES: Record<number, { border: string; bg: string; badge: string; text: string }> = {
  1: { border: "border-yellow-400", bg: "bg-gradient-to-r from-yellow-400/10 to-yellow-500/5", badge: "bg-yellow-400 text-yellow-900", text: "text-yellow-400" },
  2: { border: "border-gray-300", bg: "bg-gradient-to-r from-gray-300/10 to-gray-400/5", badge: "bg-gray-300 text-gray-700", text: "text-gray-300" },
  3: { border: "border-amber-600", bg: "bg-gradient-to-r from-amber-600/10 to-amber-700/5", badge: "bg-amber-600 text-white", text: "text-amber-600" },
};

function formatXp(n: number): string {
  if (n >= 1000) return (n / 1000).toFixed(1).replace(/\.0$/, "") + "k";
  return n.toString();
}
---

<Layout title={t(locale, "ranking.metaTitle")} description={t(locale, "ranking.metaDescription")} locale={locale}>
  <main>

    {/* Hero */}
    <section class="bg-gradient-to-b from-[#1a0e42] via-[#2d1b69] to-[#1a0e42] pt-12 pb-16 relative overflow-hidden">
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 28px 28px;"></div>
      <div class="relative max-w-4xl mx-auto px-4 text-center">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm rounded-full px-4 py-1.5 mb-6">
          <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 24 24"><path d="M5 16L3 5l5.5 5L12 4l3.5 6L21 5l-2 11H5zm14 3c0 .6-.4 1-1 1H6c-.6 0-1-.4-1-1v-1h14v1z"/></svg>
          <span class="text-yellow-400 font-bold text-xs uppercase tracking-widest">{t(locale, "ranking.title")}</span>
        </div>
        <h1 class="font-display text-4xl md:text-5xl font-black text-white leading-tight mb-4">{t(locale, "ranking.title")}</h1>
        <p class="text-white/50 text-base md:text-lg max-w-xl mx-auto leading-relaxed">{t(locale, "ranking.subtitle")}</p>
      </div>
    </section>

    {/* Filter tabs */}
    <section class="bg-white border-b border-gray-100 sticky top-0 z-20">
      <div class="max-w-4xl mx-auto px-4">
        <div class="flex gap-1 py-3">
          <button class="px-5 py-2 rounded-lg text-sm font-bold bg-violet-600 text-white shadow-sm transition-all">
            {t(locale, "ranking.allTime")}
          </button>
          <button class="px-5 py-2 rounded-lg text-sm font-bold text-gray-400 hover:text-gray-600 hover:bg-gray-50 transition-all">
            {t(locale, "ranking.thisWeek")}
          </button>
          <button class="px-5 py-2 rounded-lg text-sm font-bold text-gray-400 hover:text-gray-600 hover:bg-gray-50 transition-all">
            {t(locale, "ranking.thisMonth")}
          </button>
        </div>
      </div>
    </section>

    {/* Top 3 podium */}
    <section class="max-w-4xl mx-auto px-4 pt-10 pb-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {mockPlayers.slice(0, 3).map((player) => {
          const style = RANK_STYLES[player.rank]!;
          const isFirst = player.rank === 1;
          return (
            <div class={`relative rounded-2xl border-2 ${style.border} ${style.bg} p-6 text-center ${isFirst ? "md:-mt-4 md:pb-8" : ""} transition-all hover:shadow-lg hover:-translate-y-1`}>
              {isFirst && (
                <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                  <svg class="w-8 h-8 text-yellow-400 drop-shadow-lg" fill="currentColor" viewBox="0 0 24 24"><path d="M5 16L3 5l5.5 5L12 4l3.5 6L21 5l-2 11H5zm14 3c0 .6-.4 1-1 1H6c-.6 0-1-.4-1-1v-1h14v1z"/></svg>
                </div>
              )}
              <div class={`w-16 h-16 ${isFirst ? "w-20 h-20" : ""} mx-auto rounded-full ${style.badge} flex items-center justify-center text-2xl ${isFirst ? "text-3xl" : ""} font-black mb-3 shadow-lg`}>
                {player.avatar}
              </div>
              <span class={`inline-block text-xs font-black ${style.badge} px-3 py-1 rounded-full mb-2`}>
                #{player.rank}
              </span>
              <h3 class="font-display font-bold text-gray-900 text-base mb-1">{player.username}</h3>
              <div class="flex items-center justify-center gap-1 mb-3">
                <span class="text-[10px] font-bold bg-violet-100 text-violet-600 px-2 py-0.5 rounded">
                  {t(locale, "ranking.level")} {player.level}
                </span>
              </div>
              <div class="flex items-center justify-center gap-4 text-sm">
                <div>
                  <p class={`font-black text-lg ${style.text}`}>{formatXp(player.xp)}</p>
                  <p class="text-[10px] text-gray-400 font-semibold uppercase">{t(locale, "ranking.xp")}</p>
                </div>
                <div class="w-px h-8 bg-gray-200"></div>
                <div>
                  <p class="font-black text-lg text-gray-700">{player.quizzes}</p>
                  <p class="text-[10px] text-gray-400 font-semibold uppercase">{t(locale, "ranking.quizzes")}</p>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    {/* Full leaderboard table */}
    <section class="max-w-4xl mx-auto px-4 pb-16">
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
        {/* Table header */}
        <div class="grid grid-cols-[60px_1fr_100px_100px_100px] md:grid-cols-[80px_1fr_120px_120px_120px] items-center px-4 md:px-6 py-3 bg-gray-50 border-b border-gray-100 text-[10px] font-bold text-gray-400 uppercase tracking-widest">
          <span>{t(locale, "ranking.rank")}</span>
          <span>{t(locale, "ranking.player")}</span>
          <span class="text-center">{t(locale, "ranking.level")}</span>
          <span class="text-center">{t(locale, "ranking.xp")}</span>
          <span class="text-center hidden md:block">{t(locale, "ranking.quizzes")}</span>
        </div>

        {/* Rows */}
        {mockPlayers.slice(3).map((player, i) => (
          <div class={`grid grid-cols-[60px_1fr_100px_100px_100px] md:grid-cols-[80px_1fr_120px_120px_120px] items-center px-4 md:px-6 py-4 border-b border-gray-50 hover:bg-violet-50/50 transition-colors ${i % 2 === 0 ? "bg-white" : "bg-gray-50/30"}`}>
            <span class="text-sm font-black text-gray-300">#{player.rank}</span>
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full bg-gradient-to-br from-violet-500 to-violet-600 flex items-center justify-center text-white text-sm font-bold shrink-0 shadow-sm">
                {player.avatar}
              </div>
              <span class="text-sm font-bold text-gray-900 truncate">{player.username}</span>
            </div>
            <div class="text-center">
              <span class="text-xs font-bold bg-violet-100 text-violet-600 px-2.5 py-1 rounded-full">
                {player.level}
              </span>
            </div>
            <div class="text-center">
              <span class="text-sm font-black text-gray-700">{formatXp(player.xp)}</span>
            </div>
            <div class="text-center hidden md:block">
              <span class="text-sm font-semibold text-gray-500">{player.quizzes}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    {/* CTA */}
    <section class="max-w-4xl mx-auto px-4 pb-16">
      <div class="relative overflow-hidden rounded-2xl bg-gradient-to-r from-[#1a0e42] to-[#5D2DC7] p-8 md:p-12 text-center">
        <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 24px 24px;"></div>
        <div class="relative space-y-4">
          <svg class="w-10 h-10 text-yellow-400 mx-auto" fill="currentColor" viewBox="0 0 24 24"><path d="M5 16L3 5l5.5 5L12 4l3.5 6L21 5l-2 11H5zm14 3c0 .6-.4 1-1 1H6c-.6 0-1-.4-1-1v-1h14v1z"/></svg>
          <h2 class="font-display text-2xl md:text-3xl font-black text-white">Want to join the leaderboard?</h2>
          <p class="text-white/50 text-sm max-w-md mx-auto">Play quizzes, earn XP and compete with thousands of players. It's free.</p>
          <a href={lp("/")} class="inline-flex items-center gap-2 bg-yellow-500 hover:bg-yellow-400 text-white font-bold text-sm px-6 py-3 rounded-lg transition-colors shadow-lg hover:shadow-xl">Start playing now</a>
        </div>
      </div>
    </section>

  </main>
</Layout>
