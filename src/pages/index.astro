---
import Layout from "../layouts/Layout.astro";
import { MiniQCM, MiniVraiFaux, MiniEstimation } from "../components/MiniQuizzes";
import { allQuizzes } from "../data/quizzes";
import { categories, gameTypes } from "../data/categories";

const popularQuizzes = [...allQuizzes].sort((a, b) => (b.playCount || 0) - (a.playCount || 0));
const newestQuizzes = [...allQuizzes].slice(-4).reverse();
const totalPlays = allQuizzes.reduce((sum, q) => sum + (q.playCount || 0), 0);

// Question du jour
const qdj = allQuizzes[0]?.questions[0];

const DIFFICULTY_STYLE: Record<string, string> = {
  "Facile": "text-green-700 bg-green-100",
  "Moyen": "text-amber-700 bg-amber-100",
  "Difficile": "text-red-700 bg-red-100",
};
const GAME_TYPE_LABELS: Record<string, string> = {
  "qcm": "QCM", "vrai-faux": "Vrai/Faux", "chrono": "Chrono",
  "estimation": "Estimation", "duel": "Duel", "ordre": "Ordre",
};

function formatCount(n: number): string {
  if (n >= 1000) return (n / 1000).toFixed(1).replace(/\.0$/, '') + 'k';
  return n.toString();
}
---

<Layout title="Quiz.fr - Teste tes connaissances avec des quiz fun et gratuits">
  <main>

    {/* ===== HERO — texte à gauche + Question du Jour à droite ===== */}
    <section class="bg-gradient-to-b from-[#1a0e42] via-[#2d1b69] to-[#1a0e42] pt-8 pb-12 relative overflow-hidden">
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 28px 28px;"></div>
      <div class="relative max-w-5xl mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-[1fr_370px] gap-5 items-center">
          {/* Left */}
          <div class="space-y-5">
            <p class="text-yellow-400 font-bold text-xs uppercase tracking-[0.2em]">La plateforme de quiz n°1</p>
            <h1 class="font-display text-3xl md:text-5xl font-black text-white leading-tight">
              Des quiz pour<br/><span class="text-yellow-400">chaque passion</span>
            </h1>
            <p class="text-white/50 text-sm md:text-base max-w-md">
              {allQuizzes.length * 40}+ questions de Culture Générale, Géographie, Histoire, Cinéma, Sport...
            </p>
            <div class="max-w-sm">
              <div class="relative">
                <input type="text" placeholder="Football, Harry Potter, Drapeaux..." class="w-full h-11 pl-4 pr-14 rounded-lg bg-white/10 border border-white/20 text-white placeholder-white/30 text-sm focus:outline-none focus:bg-white/15 focus:border-yellow-400 transition-all" />
                <button class="absolute right-1 top-1 h-9 w-11 rounded-md bg-yellow-500 hover:bg-yellow-400 flex items-center justify-center transition-colors">
                  <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={2.5}><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                </button>
              </div>
            </div>
          </div>

          {/* Right: Question du Jour */}
          <div class="bg-white rounded-xl p-5 shadow-2xl border border-gray-100">
            <div class="flex items-center gap-2 mb-4">
              <span class="w-8 h-8 bg-violet-100 rounded-lg flex items-center justify-center text-base">📅</span>
              <div>
                <h3 class="font-display font-bold text-sm text-gray-900">Question du Jour</h3>
                <p class="text-[10px] text-gray-400 font-semibold uppercase tracking-wide">18 Mars 2026</p>
              </div>
              <span class="ml-auto text-[10px] font-bold bg-violet-100 text-violet-600 px-2 py-0.5 rounded">Quotidien</span>
            </div>
            {qdj && (
              <div class="space-y-3">
                {qdj.image && <img src={qdj.image} alt="" class="w-full aspect-video object-cover rounded-lg" />}
                <p class="font-display font-bold text-gray-900 text-sm leading-snug">{qdj.question}</p>
                <div class="grid grid-cols-2 gap-2">
                  {qdj.answers.map((a) => (
                    <button class="text-left text-xs font-semibold px-3 py-2.5 rounded-lg border border-gray-200 hover:border-violet-400 hover:bg-violet-50 text-gray-700 hover:text-violet-700 transition-all cursor-pointer">
                      {a.text}
                    </button>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    </section>

    {/* ===== QUIZ POPULAIRES — scroll ronds ===== */}
    <section class="bg-gradient-to-r from-[#2d1b69] to-[#1a0e42] py-5 border-t border-white/5">
      <div class="max-w-6xl mx-auto px-4">
        <h2 class="font-display text-sm font-bold text-yellow-400 italic mb-4">Quizz Populaires</h2>
        <div class="flex gap-5 overflow-x-auto pb-2 scrollbar-hide" style="scrollbar-width: none;">
          {popularQuizzes.slice(0, 10).map((quiz, i) => (
            <a href={`/quiz/${quiz.slug}`} class="group shrink-0 flex flex-col items-center gap-2 w-[90px]">
              <div class="relative">
                <div class="w-[72px] h-[72px] rounded-full overflow-hidden border-[3px] border-yellow-400 group-hover:border-yellow-300 transition-colors shadow-lg">
                  {quiz.coverImage ? (
                    <img src={quiz.coverImage} alt={quiz.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300" loading="lazy" />
                  ) : (
                    <div class="w-full h-full bg-violet-600 flex items-center justify-center text-white font-bold text-lg">Q</div>
                  )}
                </div>
                {i < 3 && <span class="absolute -top-1 -right-1 w-5 h-5 bg-orange-500 rounded-full text-white text-[9px] font-black flex items-center justify-center border-2 border-[#2d1b69]">#{i+1}</span>}
              </div>
              <p class="text-[10px] text-white/60 group-hover:text-white font-semibold text-center leading-tight line-clamp-2 transition-colors">{quiz.title.replace(/^Quiz\s*/i, '').substring(0, 25)}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    {/* placeholder — mini quizzes are dispersed below */}

    {/* ===== QUIZ À LA UNE — grand featured ===== */}
    <section class="max-w-6xl mx-auto px-4 pt-10 pb-6">
      {(() => {
        const featured = popularQuizzes[0];
        return featured && (
          <a href={`/quiz/${featured.slug}`} class="group block relative rounded-2xl overflow-hidden aspect-[21/8]">
            {featured.coverImage && <img src={featured.coverImage} alt={featured.title} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />}
            <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/40 to-transparent"></div>
            <div class="relative h-full flex flex-col justify-center p-8 md:p-12 max-w-lg">
              <div class="flex items-center gap-2 mb-3">
                <span class="text-[10px] font-bold bg-orange-500 text-white px-2 py-0.5 rounded">🔥 Quiz le plus joué</span>
                <span class={`text-[10px] font-bold px-2 py-0.5 rounded ${DIFFICULTY_STYLE[featured.difficulty]}`}>{featured.difficulty}</span>
                <span class="text-[10px] font-bold bg-white/20 text-white px-2 py-0.5 rounded backdrop-blur-sm">{GAME_TYPE_LABELS[featured.gameType] || "QCM"}</span>
              </div>
              <h2 class="font-display text-2xl md:text-3xl font-black text-white leading-tight mb-2">{featured.title}</h2>
              <p class="text-sm text-white/60 line-clamp-2 mb-4">{featured.description}</p>
              <div class="flex items-center gap-4 text-xs text-white/50">
                <span>{featured.questions.length} questions</span>
                {featured.playCount && <span class="font-bold text-yellow-400">{formatCount(featured.playCount)} parties</span>}
              </div>
            </div>
          </a>
        );
      })()}
    </section>

    {/* ===== GRILLE DE QUIZ — 4 colonnes, grandes images ===== */}
    <section class="max-w-6xl mx-auto px-4 pb-12">
      <div class="flex items-center justify-between mb-6">
        <h2 class="font-display text-xl font-bold text-gray-900">⭐ Quiz Incontournables</h2>
        <a href="/" class="text-xs font-bold text-violet-600 hover:text-violet-800 transition-colors">Tout voir →</a>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        {popularQuizzes.slice(1, 9).map((quiz) => (
          <a href={`/quiz/${quiz.slug}`} class="group relative rounded-xl overflow-hidden aspect-[3/4] cursor-pointer">
            {quiz.coverImage && <img src={quiz.coverImage} alt={quiz.title} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />}
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
            {/* Top badges */}
            <div class="absolute top-3 left-3 flex gap-1.5">
              <span class={`text-[10px] font-bold px-2 py-0.5 rounded ${DIFFICULTY_STYLE[quiz.difficulty]}`}>{quiz.difficulty}</span>
            </div>
            <div class="absolute top-3 right-3">
              <span class="text-[10px] font-bold bg-black/40 text-white px-2 py-0.5 rounded backdrop-blur-sm">{GAME_TYPE_LABELS[quiz.gameType] || "QCM"}</span>
            </div>
            {/* Bottom content */}
            <div class="absolute bottom-0 left-0 right-0 p-4">
              <h3 class="font-display text-sm font-bold text-white leading-tight line-clamp-2 mb-1.5">{quiz.title}</h3>
              <div class="flex items-center justify-between text-[10px] text-white/50">
                <span>{quiz.questions.length} questions</span>
                {quiz.playCount && <span class="font-bold text-yellow-400">{formatCount(quiz.playCount)}</span>}
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    {/* ===== NOUVEAUX QUIZ — horizontal scroll ===== */}
    <section class="bg-gray-50 py-10">
      <div class="max-w-6xl mx-auto px-4">
        <h2 class="font-display text-xl font-bold text-gray-900 mb-6">🆕 Ajoutés récemment</h2>
        <div class="flex gap-4 overflow-x-auto pb-2 scrollbar-hide" style="scrollbar-width: none;">
          {newestQuizzes.map((quiz, i) => (
            <a href={`/quiz/${quiz.slug}`} class="group shrink-0 w-[240px] bg-white rounded-xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
              <div class="relative aspect-video overflow-hidden">
                {quiz.coverImage && <img src={quiz.coverImage} alt={quiz.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />}
                <div class="absolute top-2 left-2">
                  <span class="text-[9px] font-bold bg-green-500 text-white px-2 py-0.5 rounded">Nouveau</span>
                </div>
              </div>
              <div class="p-3">
                <p class="text-[10px] font-bold text-violet-500 uppercase tracking-wide mb-0.5">{quiz.category}</p>
                <h3 class="text-sm font-bold text-gray-900 group-hover:text-violet-700 leading-tight line-clamp-2 transition-colors">{quiz.title}</h3>
                <p class="text-[10px] text-gray-400 mt-1">{['18 Mars', '17 Mars', '16 Mars', '15 Mars'][i]} 2026 • {quiz.questions.length} questions</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    {/* ===== SEO + MINI QCM côte à côte ===== */}
    <section class="max-w-6xl mx-auto px-4 py-10">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_340px] gap-8 items-start">
        <div>
          <h2 class="font-display text-lg font-bold text-gray-900 mb-3">On a tous ce pote incollable en soirée...</h2>
          <div class="text-sm text-gray-500 leading-relaxed space-y-3">
            <p>Tu sais, celui qui sort des anecdotes sur les JO de 1936 entre deux parts de pizza. Celui qui connaît la capitale du Bhoutan et le nombre exact de dents d'un escargot. Eh bien ce pote-là, il s'entraîne probablement sur des quiz en ligne, et honnêtement c'est comme ça qu'on a eu l'idée de créer <strong class="text-gray-700">Quiz.fr</strong>.</p>
            <p>L'objectif c'était simple : proposer des quiz qui donnent vraiment envie de jouer. Pas des questionnaires scolaires barbants, mais des <a href="/categorie/sport" class="text-violet-600 hover:underline">quiz sport</a> où tu découvres que Pelé a marqué plus de 1 000 buts, des <a href="/categorie/cinema" class="text-violet-600 hover:underline">quiz cinéma</a> qui te font réaliser que tu ne connais rien à Disney, ou des <a href="/categorie/geographie" class="text-violet-600 hover:underline">quiz géographie</a> où tu confonds encore le drapeau de Monaco et celui de l'Indonésie (on est passés par là aussi).</p>
            <p>Et le meilleur ? Chaque question vient avec son explication. Tu te trompes, tu apprends. Tu as raison, tu apprends quand même. C'est le truc cool avec les quiz : on retient 10 fois mieux une info quand on a essayé de deviner la réponse.</p>
          </div>
        </div>
        <div class="bg-violet-50 rounded-xl p-4 border border-violet-100">
          <div class="flex items-center gap-2 mb-3">
            <span class="w-7 h-7 bg-violet-500 rounded-lg flex items-center justify-center text-white text-xs font-bold">❓</span>
            <p class="text-xs font-bold text-violet-700">Teste-toi sur un QCM</p>
          </div>
          <MiniQCM client:load />
        </div>
      </div>
    </section>

    {/* ===== CATÉGORIES — grandes cartes portrait avec vraies images ===== */}
    <section class="max-w-6xl mx-auto px-4 py-12">
      <div class="flex items-center justify-between mb-6">
        <h2 class="font-display text-xl font-bold text-gray-900">📂 Explore par catégorie</h2>
        <a href="/" class="text-xs font-bold text-violet-600 hover:text-violet-800 transition-colors">Toutes →</a>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        {categories.map((cat) => {
          const catQuizzes = allQuizzes.filter(q => q.category.toLowerCase() === cat.name.toLowerCase());
          const coverImg = cat.coverImage || catQuizzes.find(q => q.coverImage)?.coverImage;
          return (
            <a href={`/categorie/${cat.slug}`} class="group relative overflow-hidden rounded-xl aspect-[3/4]">
              {coverImg ? (
                <img src={coverImg} alt={cat.name} class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" />
              ) : (
                <div class={`absolute inset-0 ${cat.color}`}></div>
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-black/10 group-hover:from-black/70 transition-colors"></div>
              <div class="relative h-full flex flex-col justify-end p-4 text-white">
                <span class="text-3xl mb-2 group-hover:scale-110 transition-transform origin-left">{cat.icon}</span>
                <h3 class="font-display font-bold text-lg leading-tight">{cat.name}</h3>
                <p class="text-xs text-white/60 mt-0.5">{catQuizzes.length} quiz</p>
                <div class="flex flex-wrap gap-1 mt-2">
                  {cat.subcategories.slice(0, 2).map((sub) => (
                    <span class="text-[9px] bg-white/15 backdrop-blur-sm px-1.5 py-0.5 rounded">{sub}</span>
                  ))}
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    {/* ===== 6 MODES DE JEU — strip horizontal clean ===== */}
    <section class="bg-[#1a0e42] py-10">
      <div class="max-w-6xl mx-auto px-4">
        <div class="text-center mb-8">
          <h2 class="font-display text-xl font-bold text-white mb-1">🎲 6 façons de jouer</h2>
          <p class="text-sm text-white/40">Pas juste du QCM, découvre des modes de jeu uniques</p>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
          {gameTypes.map((gt) => {
            const sampleQuiz = allQuizzes.find(q => q.gameType === gt.id);
            return (
              <div class="group relative overflow-hidden rounded-xl aspect-[3/4] cursor-pointer">
                {sampleQuiz?.coverImage ? (
                  <img src={sampleQuiz.coverImage} alt="" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" />
                ) : (
                  <div class={`absolute inset-0 ${gt.color}`}></div>
                )}
                <div class="absolute inset-0 bg-black/50 group-hover:bg-black/40 transition-colors"></div>
                <div class="relative h-full flex flex-col items-center justify-center text-center p-4 text-white">
                  <span class="text-4xl mb-3 group-hover:scale-110 transition-transform">{gt.icon}</span>
                  <h3 class="font-display font-bold text-sm leading-tight mb-1">{gt.name}</h3>
                  <p class="text-[10px] text-white/50 leading-snug line-clamp-2">{gt.description.split('.')[0]}</p>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    {/* ===== SEO + VRAI/FAUX côte à côte (inversé) ===== */}
    <section class="max-w-6xl mx-auto px-4 py-10">
      <div class="grid grid-cols-1 lg:grid-cols-[340px_1fr] gap-8 items-start">
        <div class="bg-emerald-50 rounded-xl p-4 border border-emerald-100">
          <div class="flex items-center gap-2 mb-3">
            <span class="w-7 h-7 bg-emerald-500 rounded-lg flex items-center justify-center text-white text-xs font-bold">✅</span>
            <p class="text-xs font-bold text-emerald-700">Vrai ou Faux ? A toi de trancher</p>
          </div>
          <MiniVraiFaux client:load />
        </div>
        <div>
          <h2 class="font-display text-lg font-bold text-gray-900 mb-3">Les quiz qui cartonnent en ce moment</h2>
          <div class="text-sm text-gray-500 leading-relaxed space-y-3">
            <p>Si on devait te recommander un seul quiz pour commencer, ce serait le <strong class="text-gray-700">quiz culture générale</strong>. C'est notre bestseller et c'est pas un hasard : les questions vont de "facile, tout le monde sait ça" à "ok là j'ai clairement inventé la réponse". Parfait pour se jauger.</p>
            <p>Après, chacun ses passions. Les <strong class="text-gray-700">quiz drapeaux</strong> rendent accro, tu vas voir après 3 parties tu sauras reconnaître le drapeau du Lesotho les yeux fermés. Le <a href="/categorie/cinema" class="text-violet-600 hover:underline">quiz Harry Potter</a> ? Un classique, et non, tout le monde n'est pas Gryffondor. Le <strong class="text-gray-700">blind test musique</strong> c'est le plus fun entre amis : on branche les enceintes et c'est parti.</p>
            <p>Et si t'en as marre des QCM, essaie nos modes spéciaux. Le <strong class="text-gray-700">Chrono</strong> c'est l'adrénaline pure (30 secondes, bonne chance). Le <strong class="text-gray-700">Duel</strong> c'est vicieux : "Messi ou Ronaldo, qui a le plus de buts en Ligue des Champions ?", tu crois savoir mais tu sais pas.</p>
          </div>
        </div>
      </div>
    </section>

    {/* ===== ESTIMATION — avec contexte et cadre visuel ===== */}
    <section class="max-w-6xl mx-auto px-4 pb-8">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_340px] gap-8 items-start">
        <div>
          <h2 class="font-display text-lg font-bold text-gray-900 mb-3">Un quiz, c'est pas juste 4 réponses au pif</h2>
          <div class="text-sm text-gray-500 leading-relaxed space-y-3">
            <p>Le truc qu'on voulait absolument éviter, c'est le côté "tu cliques au hasard et tu passes à la suite". Sur Quiz.fr, chaque mauvaise réponse est une occasion d'apprendre quelque chose. L'explication après chaque question, c'est notre marque de fabrique, et franchement c'est souvent la partie la plus intéressante.</p>
            <p>On a aussi bossé sur les modes de jeu pour que ça reste frais. L'<strong class="text-gray-700">Estimation</strong> par exemple, c'est complètement différent : pas de choix multiples, juste toi et un chiffre à trouver. Tu proposes un nombre, on te dit "plus haut" ou "plus bas", et tu continues jusqu'à trouver. C'est addictif, essaie juste à côté.</p>
          </div>
        </div>
        <div class="bg-cyan-50 rounded-xl p-4 border border-cyan-100">
          <div class="flex items-center gap-2 mb-3">
            <span class="w-7 h-7 bg-cyan-500 rounded-lg flex items-center justify-center text-white text-xs font-bold">🎯</span>
            <p class="text-xs font-bold text-cyan-700">Plus haut ou plus bas ?</p>
          </div>
          <MiniEstimation client:load />
        </div>
      </div>
    </section>

    {/* ===== CTA CRÉER ===== */}
    <section class="max-w-6xl mx-auto px-4 py-12">
      <div class="relative overflow-hidden rounded-2xl bg-gradient-to-r from-[#1a0e42] to-[#5D2DC7] p-8 md:p-12 text-center">
        <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 24px 24px;"></div>
        <div class="relative space-y-4">
          <span class="text-4xl">✏️</span>
          <h2 class="font-display text-2xl md:text-3xl font-black text-white">Tu as une idée de quiz ?</h2>
          <p class="text-white/50 text-sm max-w-md mx-auto">Crée-le en 5 minutes et partage-le avec tes amis. C'est gratuit, rapide et fun.</p>
          <a href="/creer" class="inline-flex items-center gap-2 bg-yellow-500 hover:bg-yellow-400 text-white font-bold text-sm px-6 py-3 rounded-lg transition-colors shadow-lg hover:shadow-xl">Créer mon quiz →</a>
        </div>
      </div>
    </section>

    {/* ===== STATS INLINE — discret ===== */}
    <section class="max-w-6xl mx-auto px-4 py-6">
      <div class="flex items-center justify-center gap-6 text-center">
        <p class="text-sm text-gray-400"><span class="font-black text-violet-600">{allQuizzes.length * 40}+</span> quiz disponibles</p>
        <span class="text-gray-200">|</span>
        <p class="text-sm text-gray-400"><span class="font-black text-violet-600">{formatCount(totalPlays)}</span> parties jouées</p>
      </div>
    </section>

    {/* ===== FAQ — accordéons stylisés, vraies questions SEO ===== */}
    <section class="bg-gray-50 py-12">
      <div class="max-w-6xl mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-[280px_1fr] gap-8">
          <div class="lg:sticky lg:top-32">
            <h2 class="font-display text-2xl font-black text-gray-900 mb-2">Questions fréquentes</h2>
            <p class="text-sm text-gray-400 leading-relaxed">Les réponses aux questions que vous nous posez le plus souvent sur Quiz.fr.</p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <details name="faq" class="bg-white rounded-xl border border-gray-100 overflow-hidden group hover:shadow-md transition-all">
              <summary class="px-5 py-4 cursor-pointer text-sm font-bold text-gray-900 flex items-center justify-between">
                Les quiz sont-ils vraiment gratuits et sans inscription ?
