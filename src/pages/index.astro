---
import Layout from "../layouts/Layout.astro";
import { MiniQCM, MiniVraiFaux, MiniEstimation } from "../components/MiniQuizzes";
import DailyQuestion from "../components/DailyQuestion";
import { getAllQuizzes } from "../data/quizzes";
import { getCategories, getGameTypes } from "../data/categories";
import { categoryIcons, gameTypeIcons } from "../data/icons";
import { localePath, withBase } from "../utils/base";
import { t } from "../i18n/ui";
import type { Locale } from "../i18n/config";

const locale: Locale = "en";
const lp = (path: string) => localePath(path, locale);
const categories = getCategories(locale);
const gameTypesData = getGameTypes(locale);
const allQuizzes = getAllQuizzes(locale);

const mainCategories = categories;
const homepageCategories = categories;

const popularQuizzes = [...allQuizzes].sort((a, b) => (b.playCount || 0) - (a.playCount || 0));
const newestQuizzes = [...allQuizzes].slice(-4).reverse();
const totalPlays = allQuizzes.reduce((sum, q) => sum + (q.playCount || 0), 0);

const qdj = allQuizzes[0]?.questions[0];

const DIFFICULTY_STYLE: Record<string, string> = {
  "Easy": "text-green-700 bg-green-100",
  "Medium": "text-amber-700 bg-amber-100",
  "Hard": "text-red-700 bg-red-100",
  "Facile": "text-green-700 bg-green-100",
  "Moyen": "text-amber-700 bg-amber-100",
  "Difficile": "text-red-700 bg-red-100",
  "Fácil": "text-green-700 bg-green-100",
  "Medio": "text-amber-700 bg-amber-100",
  "Difícil": "text-red-700 bg-red-100",
};
const GAME_TYPE_LABELS: Record<string, string> = {
  "qcm": "MCQ", "vrai-faux": "True/False", "chrono": "Chrono",
  "estimation": "Estimation", "duel": "Duel", "ordre": "Order",
};

function formatCount(n: number): string {
  if (n >= 1000) return (n / 1000).toFixed(1).replace(/\.0$/, '') + 'k';
  return n.toString();
}
---

<Layout title="Wizy - Test your knowledge with fun and free quizzes" locale={locale}>
  <main>

    {/* ===== HERO — texte à gauche + Question du Jour à droite ===== */}
    <section class="bg-gradient-to-b from-[#1a0e42] via-[#2d1b69] to-[#1a0e42] pt-8 pb-12 relative overflow-hidden">
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 28px 28px;"></div>
      <div class="relative max-w-5xl mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-[1fr_370px] gap-5 items-center">
          {/* Left */}
          <div class="space-y-5">
            <p class="text-yellow-400 font-bold text-sm uppercase tracking-[0.15em]">The #1 quiz platform</p>
            <h1 class="font-display text-4xl md:text-[3.5rem] font-black text-white leading-[1.1]">
              Quizzes for<br/><span class="text-yellow-400">every passion</span>
            </h1>
            <p class="text-white/60 text-base md:text-lg max-w-lg leading-relaxed">
              {allQuizzes.length * 40}+ questions written by experts, explanations with every answer, 6 game modes. Free, no sign-up required.
            </p>
            <div class="max-w-sm">
              <div class="relative">
                <input type="text" placeholder="Football, Harry Potter, Flags..." class="w-full h-11 pl-4 pr-14 rounded-lg bg-white/10 border border-white/20 text-white placeholder-white/30 text-sm focus:outline-none focus:bg-white/15 focus:border-yellow-400 transition-all" />
                <button class="absolute right-1 top-1 h-9 w-11 rounded-md bg-yellow-500 hover:bg-yellow-400 flex items-center justify-center transition-colors" aria-label="Search">
                  <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={2.5}><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                </button>
              </div>
            </div>
          </div>

          {/* Right: Question du Jour */}
          <div class="bg-white rounded-xl p-5 shadow-2xl border border-gray-100">
            <div class="flex items-center gap-2 mb-4">
              <span class="w-8 h-8 bg-violet-100 rounded-lg flex items-center justify-center text-violet-600 p-1.5">
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-full h-full"><path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM9 10H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2z"/></svg>
              </span>
              <div>
                <p class="font-display font-bold text-sm text-gray-900">Question of the Day</p>
                <p class="text-[10px] text-gray-400 font-semibold uppercase tracking-wide">March 18, 2026</p>
              </div>
              <span class="ml-auto text-[10px] font-bold bg-violet-100 text-violet-600 px-2 py-0.5 rounded">Daily</span>
            </div>
            {qdj && (
              <DailyQuestion
                client:load
                question={qdj.question}
                answers={qdj.answers}
                correctAnswer={qdj.correctAnswer}
                explanation={qdj.explanation}
                image={qdj.image ? withBase(qdj.image) : undefined}
                locale="en"
              />
            )}
          </div>
        </div>
      </div>
    </section>

    {/* ===== QUIZ POPULAIRES — scroll ronds ===== */}
    <section class="bg-gradient-to-r from-[#2d1b69] to-[#1a0e42] py-5 border-t border-white/5">
      <div class="max-w-6xl mx-auto px-4">
        <h2 class="font-display text-sm font-bold text-yellow-400 italic mb-4">Popular Quizzes</h2>
        <div class="flex gap-5 overflow-x-auto pb-2 scrollbar-hide" style="scrollbar-width: none;">
          {popularQuizzes.slice(0, 10).map((quiz, i) => (
            <a href={lp(`/${quiz.path}`)} class="group shrink-0 flex flex-col items-center gap-2 w-[90px]">
              <div class="relative">
                <div class="w-[72px] h-[72px] rounded-full overflow-hidden border-[3px] border-yellow-400 group-hover:border-yellow-300 transition-colors shadow-lg">
                  {quiz.coverImage ? (
                    <img src={withBase(quiz.coverImage)} alt={quiz.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300" loading="lazy" />
                  ) : (
                    <div class="w-full h-full bg-violet-600 flex items-center justify-center text-white font-bold text-lg">Q</div>
                  )}
                </div>
                {i < 3 && <span class="absolute -top-1 -right-1 w-5 h-5 bg-orange-700 rounded-full text-white text-[9px] font-black flex items-center justify-center border-2 border-[#2d1b69]">#{i+1}</span>}
              </div>
              <p class="text-[10px] text-white/60 group-hover:text-white font-semibold text-center leading-tight line-clamp-2 transition-colors">{quiz.title.replace(/^Quiz\s*/i, '').substring(0, 25)}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    {/* placeholder — mini quizzes are dispersed below */}

    {/* ===== QUIZ À LA UNE — grand featured ===== */}
    <section class="max-w-6xl mx-auto px-4 pt-10 pb-6">
      {(() => {
        const featured = popularQuizzes[0];
        return featured && (
          <a href={lp(`/${featured.path}`)} class="group block relative rounded-2xl overflow-hidden aspect-[21/8]">
            {featured.coverImage && <img src={withBase(featured.coverImage)} alt={featured.title} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />}
            <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/40 to-transparent"></div>
            <div class="relative h-full flex flex-col justify-center p-8 md:p-12 max-w-lg">
              <div class="flex items-center gap-2 mb-3">
                <span class="text-[10px] font-bold bg-orange-700 text-white px-2 py-0.5 rounded">Most played quiz</span>
                <span class={`text-[10px] font-bold px-2 py-0.5 rounded ${DIFFICULTY_STYLE[featured.difficulty]}`}>{featured.difficulty}</span>
                <span class="text-[10px] font-bold bg-white/20 text-white px-2 py-0.5 rounded backdrop-blur-sm">{GAME_TYPE_LABELS[featured.gameType] || "QCM"}</span>
              </div>
              <h2 class="font-display text-2xl md:text-3xl font-black text-white leading-tight mb-2">{featured.title}</h2>
              <p class="text-sm text-white/60 line-clamp-2 mb-4">{featured.description}</p>
              <div class="flex items-center gap-4 text-xs text-white/50">
                <span>{featured.questions.length} questions</span>
                {featured.playCount && <span class="font-bold text-yellow-400">{formatCount(featured.playCount)} plays</span>}
              </div>
            </div>
          </a>
        );
      })()}
    </section>

    {/* ===== GRILLE DE QUIZ — 4 colonnes, grandes images ===== */}
    <section class="max-w-6xl mx-auto px-4 pb-12">
      <div class="flex items-center justify-between mb-6">
        <h2 class="font-display text-xl font-bold text-gray-900">Must-Play Quizzes</h2>
        <a href={lp('/')} class="text-xs font-bold text-violet-600 hover:text-violet-800 transition-colors">See all →</a>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        {popularQuizzes.slice(1, 9).map((quiz) => (
          <a href={lp(`/${quiz.path}`)} class="group relative rounded-xl overflow-hidden aspect-[3/4] cursor-pointer">
            {quiz.coverImage && <img src={withBase(quiz.coverImage)} alt={quiz.title} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />}
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
            {/* Top badges */}
            <div class="absolute top-3 left-3 flex gap-1.5">
              <span class={`text-[10px] font-bold px-2 py-0.5 rounded ${DIFFICULTY_STYLE[quiz.difficulty]}`}>{quiz.difficulty}</span>
            </div>
            <div class="absolute top-3 right-3">
              <span class="text-[10px] font-bold bg-black/40 text-white px-2 py-0.5 rounded backdrop-blur-sm">{GAME_TYPE_LABELS[quiz.gameType] || "QCM"}</span>
            </div>
            {/* Bottom content */}
            <div class="absolute bottom-0 left-0 right-0 p-4">
              <h3 class="font-display text-sm font-bold text-white leading-tight line-clamp-2 mb-1.5">{quiz.title}</h3>
              <div class="flex items-center justify-between text-[10px] text-white/50">
                <span>{quiz.questions.length} questions</span>
                {quiz.playCount && <span class="font-bold text-yellow-400">{formatCount(quiz.playCount)}</span>}
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    {/* ===== NOUVEAUX QUIZ — horizontal scroll ===== */}
    <section class="bg-gray-50 py-10">
      <div class="max-w-6xl mx-auto px-4">
        <h2 class="font-display text-xl font-bold text-gray-900 mb-6">Recently Added</h2>
        <div class="flex gap-4 overflow-x-auto pb-2 scrollbar-hide" style="scrollbar-width: none;">
          {newestQuizzes.map((quiz, i) => (
            <a href={lp(`/${quiz.path}`)} class="group shrink-0 w-[240px] bg-white rounded-xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
              <div class="relative aspect-video overflow-hidden">
                {quiz.coverImage && <img src={withBase(quiz.coverImage)} alt={quiz.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />}
                <div class="absolute top-2 left-2">
                  <span class="text-[9px] font-bold bg-green-700 text-white px-2 py-0.5 rounded">New</span>
                </div>
              </div>
              <div class="p-3">
                <p class="text-[10px] font-bold text-violet-700 uppercase tracking-wide mb-0.5">{quiz.category}</p>
                <h3 class="text-sm font-bold text-gray-900 group-hover:text-violet-700 leading-tight line-clamp-2 transition-colors">{quiz.title}</h3>
                <p class="text-[10px] text-gray-400 mt-1">{['Mar 18', 'Mar 17', 'Mar 16', 'Mar 15'][i]} 2026 • {quiz.questions.length} questions</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    {/* ===== SEO + MINI QCM côte à côte ===== */}
    <section class="max-w-6xl mx-auto px-4 py-10">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_340px] gap-8 items-start">
        <div>
          <h2 class="font-display text-lg font-bold text-gray-900 mb-3">We all know that friend who knows everything...</h2>
          <div class="text-sm text-gray-500 leading-relaxed space-y-3">
            <p>You know, the one dropping fun facts about the 1936 Olympics between pizza slices. The one who knows the capital of Bhutan and how many teeth a snail has. Well, that friend probably trains on online quizzes, and honestly that's how we got the idea to create <strong class="text-gray-700">Wizy</strong>.</p>
            <p>The goal was simple: offer quizzes that are genuinely fun to play. Not boring school questionnaires, but <a href={lp('/sport')} class="text-violet-600 hover:underline">sports quizzes</a> where you discover that Pele scored over 1,000 goals, <a href={lp('/cinema')} class="text-violet-600 hover:underline">movie quizzes</a> that make you realize you know nothing about Disney, or <a href={lp('/geographie')} class="text-violet-600 hover:underline">geography quizzes</a> where you still mix up the flags of Monaco and Indonesia (we've been there too).</p>
            <p>And the best part? Every question comes with an explanation. Get it wrong, you learn. Get it right, you still learn. That's the cool thing about quizzes: you remember facts 10 times better when you've tried to guess the answer first.</p>
          </div>
        </div>
        <div class="bg-violet-50 rounded-xl p-4 border border-violet-100">
          <div class="flex items-center gap-2 mb-3">
            <span class="w-7 h-7 bg-violet-500 rounded-lg flex items-center justify-center text-white text-xs font-bold">?</span>
            <p class="text-xs font-bold text-violet-700">Test yourself with a MCQ</p>
          </div>
          <MiniQCM locale="en" client:idle />
        </div>
      </div>
    </section>

    {/* ===== CATÉGORIES — grandes cartes portrait avec vraies images ===== */}
    <section class="max-w-6xl mx-auto px-4 py-12">
      <div class="flex items-center justify-between mb-6">
        <h2 class="font-display text-xl font-bold text-gray-900">Explore by Category</h2>
        <a href={lp('/')} class="text-xs font-bold text-violet-600 hover:text-violet-800 transition-colors">All →</a>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
        {homepageCategories.map((cat) => {
          const catQuizzes = allQuizzes.filter(q => q.category.toLowerCase() === cat.name.toLowerCase());
          const coverImg = cat.coverImage || catQuizzes.find(q => q.coverImage)?.coverImage;
          return (
            <a href={lp(`/${cat.slug}`)} class="group relative overflow-hidden rounded-xl aspect-[3/4]">
              {coverImg ? (
                <img src={withBase(coverImg)} alt={cat.name} class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" />
              ) : (
                <div class={`absolute inset-0 ${cat.color}`}></div>
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-black/10 group-hover:from-black/70 transition-colors"></div>
              <div class="relative h-full flex flex-col justify-end p-4 text-white">
                <span class="w-8 h-8 mb-2 group-hover:scale-110 transition-transform origin-left text-white" set:html={categoryIcons[cat.slug] || cat.icon}></span>
                <h3 class="font-display font-bold text-lg leading-tight">{cat.name}</h3>
                <p class="text-xs text-white/60 mt-0.5">{catQuizzes.length} quiz</p>
                <div class="flex flex-wrap gap-1 mt-2">
                  {cat.subcategories.slice(0, 2).map((sub) => (
                    <span class="text-[9px] bg-white/15 backdrop-blur-sm px-1.5 py-0.5 rounded">{sub}</span>
                  ))}
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    {/* ===== 6 MODES DE JEU — strip horizontal clean ===== */}
    <section class="bg-[#1a0e42] py-10">
      <div class="max-w-6xl mx-auto px-4">
        <div class="text-center mb-8">
          <h2 class="font-display text-xl font-bold text-white mb-1">6 Ways to Play</h2>
          <p class="text-sm text-white/40">Not just multiple choice: discover unique game modes</p>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
          {gameTypesData.map((gt) => {
            const sampleQuiz = allQuizzes.find(q => q.gameType === gt.id);
            return (
              <div class="group relative overflow-hidden rounded-xl aspect-[3/4] cursor-pointer">
                {sampleQuiz?.coverImage ? (
                  <img src={withBase(sampleQuiz.coverImage)} alt={gt.name} class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" />
                ) : (
                  <div class={`absolute inset-0 ${gt.color}`}></div>
                )}
                <div class="absolute inset-0 bg-black/50 group-hover:bg-black/40 transition-colors"></div>
                <div class="relative h-full flex flex-col items-center justify-center text-center p-4 text-white">
                  <span class="w-10 h-10 mb-3 group-hover:scale-110 transition-transform text-white" set:html={gameTypeIcons[gt.id] || gt.icon}></span>
                  <h3 class="font-display font-bold text-sm leading-tight mb-1">{gt.name}</h3>
                  <p class="text-[10px] text-white/50 leading-snug line-clamp-2">{gt.description.split('.')[0]}</p>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    {/* ===== SEO + VRAI/FAUX côte à côte (inversé) ===== */}
    <section class="max-w-6xl mx-auto px-4 py-10">
      <div class="grid grid-cols-1 lg:grid-cols-[340px_1fr] gap-8 items-start">
        <div class="bg-emerald-50 rounded-xl p-4 border border-emerald-100">
          <div class="flex items-center gap-2 mb-3">
            <span class="w-7 h-7 bg-emerald-500 rounded-lg flex items-center justify-center text-white text-xs font-bold">V/F</span>
            <p class="text-xs font-bold text-emerald-700">True or False? You decide</p>
          </div>
          <MiniVraiFaux locale="en" client:idle />
        </div>
        <div>
          <h2 class="font-display text-lg font-bold text-gray-900 mb-3">The quizzes everyone's playing right now</h2>
          <div class="text-sm text-gray-500 leading-relaxed space-y-3">
            <p>If we had to recommend just one quiz to get started, it would be the <strong class="text-gray-700">general knowledge quiz</strong>. It's our bestseller and for good reason: the questions range from "easy, everyone knows that" to "ok I clearly made up the answer." Perfect for testing yourself.</p>
            <p>After that, to each their own passion. The <strong class="text-gray-700">flags quizzes</strong> are addictive: after 3 rounds you'll be able to recognize Lesotho's flag with your eyes closed. The <a href={lp('/cinema')} class="text-violet-600 hover:underline">Harry Potter quiz</a>? A classic, and no, not everyone is a Gryffindor. The <strong class="text-gray-700">music blind test</strong> is the most fun with friends: plug in the speakers and let's go.</p>
            <p>And if you're tired of multiple choice, try our special modes. <strong class="text-gray-700">Chrono</strong> is pure adrenaline (30 seconds, good luck). <strong class="text-gray-700">Duel</strong> is tricky: "Messi or Ronaldo, who has more Champions League goals?" You think you know, but you don't.</p>
          </div>
        </div>
      </div>
    </section>

    {/* ===== ESTIMATION — avec contexte et cadre visuel ===== */}
    <section class="max-w-6xl mx-auto px-4 pb-8">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_340px] gap-8 items-start">
        <div>
          <h2 class="font-display text-lg font-bold text-gray-900 mb-3">A quiz isn't just 4 random answers</h2>
          <div class="text-sm text-gray-500 leading-relaxed space-y-3">
            <p>The thing we absolutely wanted to avoid is the "click randomly and move on" approach. On Wizy, every wrong answer is a chance to learn something. The explanation after each question is our signature feature, and honestly it's often the most interesting part.</p>
            <p>We also worked hard on game modes to keep things fresh. <strong class="text-gray-700">Estimation</strong> for example is completely different: no multiple choice, just you and a number to find. You suggest a number, we tell you "higher" or "lower", and you keep going until you find it. It's addictive, try it right here.</p>
          </div>
        </div>
        <div class="bg-cyan-50 rounded-xl p-4 border border-cyan-100">
          <div class="flex items-center gap-2 mb-3">
            <span class="w-7 h-7 bg-cyan-500 rounded-lg flex items-center justify-center text-white text-xs font-bold">#</span>
            <p class="text-xs font-bold text-cyan-700">Higher or lower?</p>
          </div>
          <MiniEstimation locale="en" client:idle />
        </div>
      </div>
    </section>

    {/* ===== CTA CRÉER ===== */}
    <section class="max-w-6xl mx-auto px-4 py-12">
      <div class="relative overflow-hidden rounded-2xl bg-gradient-to-r from-[#1a0e42] to-[#5D2DC7] p-8 md:p-12 text-center">
        <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 24px 24px;"></div>
        <div class="relative space-y-4">
          <span class="text-4xl font-display font-black text-yellow-400">+</span>
          <h2 class="font-display text-2xl md:text-3xl font-black text-white">Got a quiz idea?</h2>
          <p class="text-white/50 text-sm max-w-md mx-auto">Create it in 5 minutes and share it with your friends. It's free, fast and fun.</p>
          <a href={lp('/creer')} class="inline-flex items-center gap-2 bg-yellow-500 hover:bg-yellow-400 text-white font-bold text-sm px-6 py-3 rounded-lg transition-colors shadow-lg hover:shadow-xl">Create my quiz →</a>
        </div>
      </div>
    </section>

    {/* ===== STATS INLINE — discret ===== */}
    <section class="max-w-6xl mx-auto px-4 py-6">
      <div class="flex items-center justify-center gap-6 text-center">
        <p class="text-sm text-gray-400"><span class="font-black text-violet-600">{allQuizzes.length * 40}+</span> quizzes available</p>
        <span class="text-gray-200">|</span>
        <p class="text-sm text-gray-400"><span class="font-black text-violet-600">{formatCount(totalPlays)}</span> games played</p>
      </div>
    </section>

    {/* ===== FAQ — accordéons stylisés, vraies questions SEO ===== */}
    <section class="bg-gray-50 py-12">
      <div class="max-w-6xl mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-[280px_1fr] gap-8">
          <div class="lg:sticky lg:top-32">
            <h2 class="font-display text-2xl font-black text-gray-900 mb-2">Frequently Asked Questions</h2>
            <p class="text-sm text-gray-400 leading-relaxed">Answers to the questions we get asked most about Wizy.</p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <details name="faq" class="bg-white rounded-xl border border-gray-100 overflow-hidden group hover:shadow-md transition-all">
