---
import Layout from "../../layouts/Layout.astro";
import { localePath } from "../../utils/base";
import { t } from "../../i18n/ui";
import type { Locale } from "../../i18n/config";

const locale: Locale = "fr";
const lp = (path: string) => localePath(path, locale);
---

<Layout title="Mentions légales - Wizy" description="Mentions légales du site Wizy." locale={locale}>
  <main class="max-w-3xl mx-auto px-4 py-12">
    <nav class="flex items-center gap-1.5 text-xs text-gray-500 mb-8" aria-label="Breadcrumb">
      <a href={lp("/")} class="hover:text-violet-600 transition-colors font-medium">{t(locale, "breadcrumb.home")}</a>
      <svg class="w-3 h-3 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      <span class="text-gray-700 font-semibold">Mentions légales</span>
    </nav>

    <h1 class="font-display text-3xl font-black text-gray-900 mb-8">Mentions légales</h1>

    <div class="prose prose-gray max-w-none space-y-8 text-sm leading-relaxed text-gray-700">

      <section>
        <h2 class="font-display text-lg font-bold text-gray-900 mb-3">1. Éditeur du site</h2>
        <p>Le site <strong>Wizy</strong> (accessible à l'adresse <strong>https://wizy.com</strong>) est édité par :</p>
        <ul class="list-disc pl-5 space-y-1 mt-2">
          <li><strong>Nom :</strong> Pierre Gaudard</li>
          <li><strong>Statut :</strong> Personne physique</li>
          <li><strong>Adresse e-mail :</strong> pierretartare94440@gmail.com</li>
        </ul>
      </section>

      <section>
        <h2 class="font-display text-lg font-bold text-gray-900 mb-3">2. Hébergeur</h2>
        <p>Le site est hébergé par :</p>
        <ul class="list-disc pl-5 space-y-1 mt-2">
          <li><strong>Raison sociale :</strong> Cloudflare, Inc.</li>
          <li><strong>Adresse :</strong> 101 Townsend Street, San Francisco, CA 94107, États-Unis</li>
          <li><strong>Site web :</strong> cloudflare.com</li>
        </ul>
      </section>

      <section>
        <h2 class="font-display text-lg font-bold text-gray-900 mb-3">3. Directeur de la publication</h2>
        <p>Le directeur de la publication est <strong>Pierre Gaudard</strong>.</p>
        <p>Contact : pierretartare94440@gmail.com</p>
      </section>

      <section>
        <h2 class="font-display text-lg font-bold text-gray-900 mb-3">4. Propriété intellectuelle</h2>
        <p>L'ensemble du contenu du site Wizy (textes, graphismes, images, logos, icônes, sons, logiciels, quiz, questions et réponses) est la propriété exclusive de Pierre Gaudard ou de ses partenaires et est protégé par les lois françaises et internationales relatives à la propriété intellectuelle.</p>
        <p>Toute reproduction, représentation, modification, publication, adaptation ou exploitation de tout ou partie des éléments du site, quel que soit le moyen ou le procédé utilisé, est interdite sauf autorisation écrite préalable de Pierre Gaudard.</p>
      </section>

      <section>
        <h2 class="font-display text-lg font-bold text-gray-900 mb-3">5. Données personnelles</h2>
        <p>Le traitement des données personnelles est détaillé dans notre <a href={lp("/confidentialite")} class="text-violet-600 hover:text-violet-800 font-medium">Politique de confidentialité</a>.</p>
      </section>

      <section>
        <h2 class="font-display text-lg font-bold text-gray-900 mb-3">6. Cookies</h2>
        <p>Le site Wizy utilise des cookies techniques strictement nécessaires au fonctionnement du site (sauvegarde de progression, préférences utilisateur). Ces cookies ne collectent aucune donnée personnelle à des fins publicitaires ou de profilage.</p>
      </section>

      <section>
        <h2 class="font-display text-lg font-bold text-gray-900 mb-3">7. Limitation de responsabilité</h2>
        <p>Les informations et contenus présents sur le site Wizy sont fournis à titre informatif et ludique. Pierre Gaudard ne saurait être tenu responsable des erreurs ou omissions dans les questions et réponses des quiz.</p>
        <p>L'utilisation du site se fait aux risques et périls de l'utilisateur. Pierre Gaudard ne pourra être tenu responsable des dommages directs ou indirects résultant de l'utilisation du site.</p>
      </section>

      <section>
        <h2 class="font-display text-lg font-bold text-gray-900 mb-3">8. Droit applicable</h2>
        <p>Les présentes mentions légales sont soumises au droit français. En cas de litige, les tribunaux français seront seuls compétents.</p>
      </section>

      <p class="text-xs text-gray-400 pt-4 border-t border-gray-200">Dernière mise à jour : mars 2026</p>
    </div>
  </main>
</Layout>
