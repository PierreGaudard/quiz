---
import Layout from "../../layouts/Layout.astro";
import { getHreflangStaticPaths } from "../../lib/hreflang-helpers";
import SearchPage from "../../components/SearchPage";
import { getAllQuizzes } from "../../data/quizzes";
import { getCategories } from "../../data/categories";
import type { Locale } from "../../i18n/config";

const locale: Locale = "fr";
const allQuizzes = getAllQuizzes(locale);
const categories = getCategories(locale);
---

<Layout title="Rechercher des quiz | Wizy" description="Recherche parmi des centaines de quiz sur Wizy. Trouve des quiz sur le sport, le cinema, les anime, les jeux video et plus encore." locale={locale} hreflangPaths={getHreflangStaticPaths("search")} noindex={true}>
  <SearchPage client:load quizzes={allQuizzes} categories={categories} locale={locale} />
</Layout>
