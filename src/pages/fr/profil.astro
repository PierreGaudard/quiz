---
import Layout from "../../layouts/Layout.astro";
import { getHreflangStaticPaths } from "../../lib/hreflang-helpers";
import ProfilePage from "../../components/ProfilePage";
import type { Locale } from "../../i18n/config";

const locale: Locale = "fr";
---

<Layout title="Mon Profil | Wizy" description="Consultez vos stats, votre niveau, vos XP et votre historique de quiz." locale={locale} hreflangPaths={getHreflangStaticPaths("profile")}>
  <ProfilePage client:load locale={locale} />
</Layout>
