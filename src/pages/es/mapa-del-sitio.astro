---
import Layout from "../../layouts/Layout.astro";
import { getCategories } from "../../data/categories";
import { getAllQuizzes, slugifySubcategory, getQuizzesByCategory, getQuizzesBySubcategory } from "../../data/quizzes";
import { localePath } from "../../utils/base";
import { t } from "../../i18n/ui";
import type { Locale } from "../../i18n/config";

const locale: Locale = "es";
const lp = (path: string) => localePath(path, locale);
const categories = getCategories(locale);
const allQuizzes = getAllQuizzes(locale);
---

<Layout title="Mapa del sitio: todos los quizzes | Wizy" description="Explora el mapa del sitio Wizy con todas las categorias, subcategorias y quizzes disponibles." locale={locale}>
  <main class="max-w-6xl mx-auto px-4 py-12">
    <nav class="flex items-center gap-1.5 text-xs text-gray-500 mb-8" aria-label="Breadcrumb">
      <a href={lp("/")} class="hover:text-violet-600 transition-colors font-medium">{t(locale, "breadcrumb.home")}</a>
      <svg class="w-3 h-3 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      <span class="text-gray-700 font-semibold">{t(locale, "sitemap.title")}</span>
    </nav>

    <h1 class="font-display text-3xl font-black text-gray-900 mb-3">{t(locale, "sitemap.title")}</h1>
    <p class="text-sm text-gray-500 mb-10">{allQuizzes.length} quizzes · {categories.length} categorías · Todas las páginas de Wizy</p>

    {/* Páginas principales */}
    <section class="mb-10">
      <h2 class="font-display text-lg font-bold text-gray-900 mb-4">{t(locale, "sitemap.mainPages")}</h2>
      <div class="flex flex-wrap gap-2">
        <a href={lp("/")} class="px-4 py-2 rounded-lg bg-violet-50 text-violet-700 text-sm font-medium hover:bg-violet-100 transition-colors">{t(locale, "breadcrumb.home")}</a>
        <a href={lp("/crear")} class="px-4 py-2 rounded-lg bg-violet-50 text-violet-700 text-sm font-medium hover:bg-violet-100 transition-colors">{t(locale, "nav.create")}</a>
        <a href={lp("/aviso-legal")} class="px-4 py-2 rounded-lg bg-gray-100 text-gray-700 text-sm font-medium hover:bg-gray-200 transition-colors">{t(locale, "footer.legal")}</a>
        <a href={lp("/politica-privacidad")} class="px-4 py-2 rounded-lg bg-gray-100 text-gray-700 text-sm font-medium hover:bg-gray-200 transition-colors">{t(locale, "footer.privacy")}</a>
        <a href={lp("/condiciones-uso")} class="px-4 py-2 rounded-lg bg-gray-100 text-gray-700 text-sm font-medium hover:bg-gray-200 transition-colors">{t(locale, "footer.terms")}</a>
      </div>
    </section>

    {/* Categorías con subcategorías y quizzes */}
    <section>
      <h2 class="font-display text-lg font-bold text-gray-900 mb-6">{t(locale, "sitemap.allCategories")}</h2>

      <div class="space-y-8">
        {categories.map((cat) => {
          const catQuizzes = getQuizzesByCategory(cat.slug, locale);
          return (
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
              {/* Category header */}
              <div class={`${cat.color} px-5 py-3 flex items-center justify-between`}>
                <a href={lp(`/${cat.slug}`)} class="font-display font-bold text-white text-base hover:underline">
                  {cat.name}
                </a>
                <span class="text-xs text-white/70 font-medium">{catQuizzes.length} {t(locale, "cat.quizzes")}</span>
              </div>

              <div class="p-5">
                {/* Subcategorías */}
                {cat.subcategories.length > 0 && (
                  <div class="mb-4">
                    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">{t(locale, "cat.subcategories")}</p>
                    <div class="flex flex-wrap gap-1.5">
                      {cat.subcategories.map((sub) => {
                        const subSlug = slugifySubcategory(sub);
                        const subQuizzes = getQuizzesBySubcategory(cat.slug, subSlug, locale);
                        return (
                          <a
                            href={lp(`/${cat.slug}/${subSlug}`)}
                            class="inline-flex items-center gap-1 px-3 py-1.5 rounded-full border border-gray-200 text-xs font-medium text-gray-600 hover:border-violet-300 hover:text-violet-700 hover:bg-violet-50 transition-all"
                          >
                            {sub}
                            {subQuizzes.length > 0 && <span class="text-gray-400">({subQuizzes.length})</span>}
                          </a>
                        );
                      })}
                    </div>
                  </div>
                )}

                {/* Quizzes de esta categoría */}
                {catQuizzes.length > 0 && (
                  <div>
                    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Quiz</p>
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-4 gap-y-1">
                      {catQuizzes.map((q) => (
                        <a
                          href={lp(`/${q.path}`)}
                          class="text-sm text-gray-600 hover:text-violet-600 transition-colors py-1 truncate"
                        >
                          {q.title}
                        </a>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </section>
  </main>
</Layout>
