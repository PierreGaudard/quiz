---
import Layout from "../../layouts/Layout.astro";
import CategoryPage from "../../components/CategoryPage";
import { localePath } from "../../utils/base";
import { t } from "../../i18n/ui";
import { getSlugPaths, resolveCategoryData } from "../../lib/page-helpers";
import type { Locale } from "../../i18n/config";

const locale: Locale = "es";

export function getStaticPaths() {
  return getSlugPaths("es");
}

const { categorySlug } = Astro.props;
const { category, catQuizzes, featured, availableGameTypes, quizzesByType } = resolveCategoryData(categorySlug, locale);
const lp = (path: string) => localePath(path, locale);
---

<Layout title={`${category.name} Quiz - Test your knowledge`} description={category.seoIntro || category.description} locale={locale}>
  <CategoryPage
    client:load
    category={category}
    quizzes={catQuizzes}
    featured={featured}
    gameTypes={availableGameTypes}
    quizzesByType={quizzesByType}
    locale={locale}
  />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: `${category.name} Quiz`,
    description: category.seoIntro || category.description,
    url: `${Astro.site?.toString().replace(/\/$/, '')}/es/${category.slug}`,
    inLanguage: "es",
    provider: { "@type": "Organization", name: "Wizy", url: Astro.site?.toString() },
    numberOfItems: catQuizzes.length,
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Inicio", item: `${Astro.site?.toString().replace(/\/$/, '')}/es/` },
      { "@type": "ListItem", position: 2, name: category.name },
    ]
  })} />
</Layout>
