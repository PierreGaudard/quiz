---
import Layout from "../../layouts/Layout.astro";
import { getHreflangStaticPaths } from "../../lib/hreflang-helpers";
import LeaderboardPage from "../../components/LeaderboardPage";
import { t } from "../../i18n/ui";
import type { Locale } from "../../i18n/config";

const locale: Locale = "es";
---

<Layout title={t(locale, "ranking.metaTitle")} description={t(locale, "ranking.metaDescription")} locale={locale} hreflangPaths={getHreflangStaticPaths("leaderboard")}>
  <LeaderboardPage client:load locale={locale} />
</Layout>
